## MCP Protocol Message Flow

```typescript
// MCPMessageHandler routes these methods:
switch (message.method) {
  case 'initialize':   // Handshake — returns serverInfo + capabilities
  case 'tools/list':   // Returns BankingToolRegistry.getAllTools()
  case 'tools/call':   // Executes tool via BankingToolProvider
}

// MessageHandlerContext — passed with every message
interface MessageHandlerContext {
  connectionId: string;
  agentToken?: string;  // Bearer token from the banking_api_server (T2)
  session?: BankingSession;
  userEmail?: string;   // injected at connection for CIBA flows
  sendNotification?: (notification: object) => void;  // push updates to client
}
```

