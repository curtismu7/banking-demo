# =============================================================================
# Banking monorepo — environment variable catalog (NO REAL SECRETS HERE)
# =============================================================================
# Copy sections into each app’s .env when moving between PingOne tenants, hosts,
# or cloud accounts. Values shown are placeholders unless noted as defaults.
#
# Apps: banking_api_server (BFF), banking_api_ui, banking_mcp_server, langchain_agent
# Platforms: local, Vercel, Replit, Railway/Render/Fly (MCP)
#
# Related templates: .env.vercel.example, .env.replit.example, banking_api_server/env.example
# =============================================================================

# -----------------------------------------------------------------------------
# Core — runtime & URLs
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
PUBLIC_APP_URL=http://localhost:3000
# Hosted BFF + UI on one origin (example): PUBLIC_APP_URL=https://api.pingdeme.org REACT_APP_CLIENT_URL=https://api.pingdeme.org
REACT_APP_CLIENT_URL=http://localhost:3000
FRONTEND_ADMIN_URL=http://localhost:3000/admin
FRONTEND_DASHBOARD_URL=http://localhost:3000/dashboard
CORS_ORIGIN=http://localhost:3000
VERCEL_PROJECT_PRODUCTION_URL=
# Vercel sets VERCEL=1 automatically

# -----------------------------------------------------------------------------
# banking_api_ui (React — REACT_APP_* baked at build time on Vercel)
# Default dev server port is often 3000 (see banking_api_ui package.json).
# -----------------------------------------------------------------------------
REACT_APP_API_URL=http://localhost:3001
REACT_APP_ENDUSER_AUDIENCE=banking_jk_enduser
REACT_APP_AI_AGENT_AUDIENCE=banking_mcp_01_JK
# Optional: MCP inspector / LangChain tooling (see server mcpInspector route)
# REACT_APP_LANGCHAIN_INSPECTOR_URL=http://localhost:8081/inspector/mcp-host

# -----------------------------------------------------------------------------
# Session & cookies (BFF)
# -----------------------------------------------------------------------------
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-session-secret-key-change-this-in-production
CONFIG_ENCRYPTION_KEY=
# Redis session store (required on Vercel multi-instance; optional locally)
REDIS_URL=
# Upstash REST (alternative to REDIS_URL for sessions / KV)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Vercel KV (config hash + optional features)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# -----------------------------------------------------------------------------
# PingOne — tenant (canonical + alternates used in code)
# -----------------------------------------------------------------------------
PINGONE_ENVIRONMENT_ID=your-environment-uuid
PINGONE_ENV_ID=
PINGONE_REGION=com
PINGONE_CORE_TENANT_NAME=your-tenant-name

# Admin / staff OAuth app (names are aliases — set one family consistently)
PINGONE_AI_CORE_CLIENT_ID=your-admin-client-id
PINGONE_AI_CORE_CLIENT_SECRET=your-admin-client-secret
# Register both in PingOne if you use local + hosted API (see GET /api/auth/oauth/redirect-info → referenceRedirectSets)
PINGONE_AI_CORE_REDIRECT_URI=http://localhost:3001/api/auth/oauth/callback
# PINGONE_AI_CORE_REDIRECT_URI=https://api.pingdeme.org/api/auth/oauth/callback
PINGONE_CORE_CLIENT_ID=
PINGONE_CORE_CLIENT_SECRET=
PINGONE_CORE_REDIRECT_URI=
PINGONE_ADMIN_CLIENT_ID=
PINGONE_ADMIN_CLIENT_SECRET=
PINGONE_ADMIN_REDIRECT_URI=

# End-user OAuth app
PINGONE_AI_CORE_USER_CLIENT_ID=your-user-client-id
PINGONE_AI_CORE_USER_CLIENT_SECRET=your-user-client-secret
PINGONE_AI_CORE_USER_REDIRECT_URI=http://localhost:3001/api/auth/oauth/user/callback
# PINGONE_AI_CORE_USER_REDIRECT_URI=https://api.pingdeme.org/api/auth/oauth/user/callback
PINGONE_CORE_USER_CLIENT_ID=
PINGONE_CORE_USER_CLIENT_SECRET=
PINGONE_CORE_USER_REDIRECT_URI=
PINGONE_USER_CLIENT_ID=
PINGONE_USER_CLIENT_SECRET=
PINGONE_USER_REDIRECT_URI=

# Vite / legacy fallbacks (configStore may read these)
VITE_PINGONE_CLIENT_ID=
VITE_PINGONE_CLIENT_SECRET=

# Pi.flow / DaVinci browserless flows (only if app supports)
# PINGONE_ADMIN_AUTHORIZE_PI_FLOW=false
# PINGONE_USER_AUTHORIZE_PI_FLOW=false

# Token revocation (optional explicit endpoint)
PINGONE_REVOCATION_ENDPOINT=

# PingOne Management API (agent user provisioning / mapping — optional)
PINGONE_MANAGEMENT_API_TOKEN=
PINGONE_WORKER_ACCESS_TOKEN=
PINGONE_AGENT_POPULATION_ID=
PINGONE_AGENT_MAPPING_ATTR_NAME=bankingPrincipalUserId
PINGONE_AGENT_USERNAME_PREFIX=
PINGONE_PROVISION_AGENT_USER=false
PINGONE_ROPC_FOR_AGENT_BOOTSTRAP=false

# -----------------------------------------------------------------------------
# Token validation / audiences (BFF middleware)
# -----------------------------------------------------------------------------
ENDUSER_AUDIENCE=banking_jk_enduser
AI_AGENT_AUDIENCE=banking_mcp_01_JK
AI_AGENT_SCOPE=ai_agent
ADMIN_ROLE=admin
USER_ROLE=customer
DEFAULT_USER_TYPE=customer
STRICT_SCOPE_VALIDATION=true
SCOPE_VALIDATION_TIMEOUT=10000
CACHE_TOKEN_VALIDATION=true
TOKEN_CACHE_TTL=600
DEBUG_SCOPES=false
SKIP_TOKEN_SIGNATURE_VALIDATION=false
# Introspection (optional)
PINGONE_INTROSPECTION_ENDPOINT=
PINGONE_CLIENT_ID=
PINGONE_CLIENT_SECRET=
ENABLE_TOKEN_INTROSPECTION=
INTROSPECTION_FAIL_OPEN=

# -----------------------------------------------------------------------------
# MCP + RFC 8693 (BFF ↔ banking_mcp_server)
# -----------------------------------------------------------------------------
MCP_SERVER_URL=ws://localhost:8080
MCP_SERVER_RESOURCE_URI=https://your-mcp-resource-audience-uri
MCP_WS_MAX_CONCURRENT=8
AGENT_OAUTH_CLIENT_ID=
AGENT_OAUTH_CLIENT_SECRET=
AGENT_OAUTH_CLIENT_SCOPES=openid
USE_AGENT_ACTOR_FOR_MCP=false
BFF_CLIENT_ID=
REQUIRE_MAY_ACT=false

# -----------------------------------------------------------------------------
# PingOne Authorize (policy / worker — optional)
# -----------------------------------------------------------------------------
AUTHORIZE_ENABLED=false
PINGONE_AUTHORIZE_WORKER_CLIENT_ID=
PINGONE_AUTHORIZE_WORKER_CLIENT_SECRET=
PINGONE_AUTHORIZE_POLICY_ID=

# -----------------------------------------------------------------------------
# Step-up MFA / CIBA (BFF)
# -----------------------------------------------------------------------------
STEP_UP_METHOD=ciba
STEP_UP_AMOUNT_THRESHOLD=250
STEP_UP_ACR_VALUE=Multi_factor
CIBA_ENABLED=false
CIBA_TOKEN_DELIVERY_MODE=poll
CIBA_BINDING_MESSAGE=Banking App Authentication
CIBA_NOTIFICATION_ENDPOINT=
CIBA_AUTH_REQUEST_EXPIRY=300
CIBA_POLL_INTERVAL_MS=5000

# -----------------------------------------------------------------------------
# AI / NL intent (BFF — Groq → Gemini → heuristic)
# -----------------------------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# -----------------------------------------------------------------------------
# Demo, logging, rate limits, JWKS
# -----------------------------------------------------------------------------
DEMO_MODE=false
DEBUG_OAUTH=false
DEBUG_TOKENS=false
# true = disable express-rate-limit on API + auth + config (testing only)
DISABLE_RATE_LIMIT=false
# Optional overrides (requests per window); global window is 15m, auth routes 1m
# RATE_LIMIT_MAX=8000
# RATE_LIMIT_AUTH_MAX=300
JWKS_REQUESTS_PER_MINUTE=30
JWKS_CACHE_MAX_AGE=600000
LOG_FILE_PATH=
LOG_LEVEL=DEBUG
MCP_LOG_VERBOSE=false

# -----------------------------------------------------------------------------
# Hosted / Replit-specific
# -----------------------------------------------------------------------------
REPL_ID=
REPLIT_DEPLOYMENT=
REPLIT_DEV_DOMAIN=
REPLIT_MANAGED_OAUTH=
REPLIT_CONFIG_PASSWORD_MODE=
ADMIN_CONFIG_PASSWORD=

# -----------------------------------------------------------------------------
# banking_mcp_server (TypeScript — copy to banking_mcp_server/.env*)
# -----------------------------------------------------------------------------
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8080
MCP_SERVER_MAX_CONNECTIONS=100
MCP_SERVER_SESSION_TIMEOUT=3600
PINGONE_BASE_URL=https://auth.pingone.com/your-env-id/as
PINGONE_CLIENT_ID=
PINGONE_CLIENT_SECRET=
PINGONE_INTROSPECTION_ENDPOINT=
PINGONE_AUTHORIZATION_ENDPOINT=
PINGONE_TOKEN_ENDPOINT=
BANKING_API_BASE_URL=http://localhost:3001
BANKING_API_TIMEOUT=30000
ENCRYPTION_KEY=
TOKEN_STORAGE_PATH=./data/tokens
SESSION_STORAGE_PATH=./data/sessions
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback
CIBA_MAX_WAIT_SECONDS=300
ENABLE_METRICS=true
METRICS_PORT=9090

# -----------------------------------------------------------------------------
# LangChain agent (optional — langchain_agent/.env)
# -----------------------------------------------------------------------------
LANGCHAIN_MODEL_NAME=
LANGCHAIN_VERBOSE=
LANGCHAIN_STREAM_MCP_TOOL_EVENTS=true
LANGCHAIN_STREAM_LLM_TOKENS=true
LANGCHAIN_WEBSOCKET_PORT=8080
# LangChain agent health HTTP (serves /inspector/mcp-host) — match REACT_APP_LANGCHAIN_INSPECTOR_URL
# HEALTH_HTTP_PORT=8081
WEBSOCKET_PORT=
OPENAI_API_KEY=
ENCRYPTION_MASTER_KEY=
ENCRYPTION_SALT=
MCP_SERVER_BANKING_ENDPOINT=

# -----------------------------------------------------------------------------
# Integration / test scripts only (never commit real tokens)
# -----------------------------------------------------------------------------
# INTEGRATION_SUBJECT_ACCESS_TOKEN=
# RUN_PINGONE_TOKEN_INTEGRATION=false
# MCP_TOKEN_EXCHANGE_SCOPES=banking:read banking:write
# VERIFY_TOKEN_EXCHANGE_WITH_ACTOR=false
# BANKING_API_BASE_URL=http://localhost:3001
# SESSION_COOKIE=

# -----------------------------------------------------------------------------
# Data / bootstrap (BFF)
# -----------------------------------------------------------------------------
# BANKING_BOOTSTRAP_FILE=./data/bootstrapData.json
# ALLOW_BOOTSTRAP_EXPORT_WRITE=false
