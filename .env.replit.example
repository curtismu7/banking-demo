# ══════════════════════════════════════════════════════════════════
#  Banking Demo — Replit Secrets configuration
#  Add each of these as a Replit Secret (padlock icon in sidebar)
# ══════════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────────
NODE_ENV=production

# PingOne tenant
PINGONE_ENVIRONMENT_ID=your-environment-uuid
PINGONE_REGION=com

# OAuth apps (Admin + Customer)
PINGONE_ADMIN_CLIENT_ID=your-admin-client-id
PINGONE_ADMIN_CLIENT_SECRET=your-admin-client-secret
PINGONE_USER_CLIENT_ID=your-user-client-id
PINGONE_USER_CLIENT_SECRET=your-user-client-secret

# Session security — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-64-char-random-hex

# Your Replit app URL (shown in the browser bar when running)
# e.g. https://banking-demo.yourusername.repl.co
PUBLIC_APP_URL=https://your-repl-name.your-username.repl.co

# ── Recommended ───────────────────────────────────────────────────
# Persistent sessions (free tier available at https://upstash.com)
# Without this, sessions reset on every Repl restart
REDIS_URL=rediss://your-upstash-redis-url

# Demo mode — disables destructive operations on shared repls
DEMO_MODE=true

# ── OAuth audience scopes (match your PingOne resource server names) ──
ENDUSER_AUDIENCE=banking_api_enduser
AI_AGENT_AUDIENCE=mcp_application

# ── Roles (must match PingOne group/role names) ────────────────────
PINGONE_ADMIN_ROLE=admin
PINGONE_USER_ROLE=customer

# ── PingOne redirect URIs to register in your PingOne apps ────────
# Admin app:    https://your-repl-name.your-username.repl.co/api/auth/oauth/callback
# Customer app: https://your-repl-name.your-username.repl.co/api/auth/oauth/user/callback
