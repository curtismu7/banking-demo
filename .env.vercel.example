# ============================================================================
# Banking Digital Assistant — Vercel Environment Variables
# ============================================================================
# Copy the values from your .env and set these in:
#   Vercel Dashboard → Project → Settings → Environment Variables
#
# Required vars are marked [REQUIRED].
# Optional vars have a default noted.
# ============================================================================

# Demo mode: disables destructive operations (transfers, account deletion) — set on shared/public deployments
DEMO_MODE=true

# ─────────────────────────────────────────────────────────────────────────────
# SESSIONS  [REQUIRED for OAuth to work on Vercel]
# ─────────────────────────────────────────────────────────────────────────────
# Without REDIS_URL the server falls back to an in-memory session store.
# On Vercel each cold start gets a fresh instance, so login → PingOne → callback
# may land on a different instance and the OAuth state check will fail.
#
# Get a free Redis URL from:
#   • Upstash  https://upstash.com  (free tier, no credit card)
#   • Vercel KV  https://vercel.com/docs/storage/vercel-kv  (add via dashboard)
REDIS_URL=rediss://<user>:<password>@<host>:<port>

# Signing secret for session cookies.  Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=<strong-random-string>

# ─────────────────────────────────────────────────────────────────────────────
# PINGONE / PingOne AI IAM Core OAUTH  [REQUIRED]
# ─────────────────────────────────────────────────────────────────────────────
# Everyone hitting the same production URL uses the SAME values in this Vercel project.
# The server also accepts PINGONE_CORE_* / PINGONE_ADMIN_* names (see configStore envFallbackMap).
PINGONE_ENVIRONMENT_ID=<your-env-id>
PINGONE_REGION=com

# Admin OAuth2 client
PINGONE_AI_CORE_CLIENT_ID=<admin-client-id>
PINGONE_AI_CORE_CLIENT_SECRET=<admin-client-secret>
# Must be registered in PingOne: https://<vercel-url>/api/auth/oauth/callback
PINGONE_AI_CORE_REDIRECT_URI=https://<your-vercel-url>.vercel.app/api/auth/oauth/callback

# End-user OAuth2 client
PINGONE_AI_CORE_USER_CLIENT_ID=<user-client-id>
PINGONE_AI_CORE_USER_CLIENT_SECRET=<user-client-secret>
# Must be registered in PingOne: https://<vercel-url>/api/auth/oauth/user/callback
PINGONE_AI_CORE_USER_REDIRECT_URI=https://<your-vercel-url>.vercel.app/api/auth/oauth/user/callback

# Frontend URL (used for post-logout redirect and OAuth error redirects)
REACT_APP_CLIENT_URL=https://<your-vercel-url>.vercel.app

# ─────────────────────────────────────────────────────────────────────────────
# MCP SERVER (Banking Agent)  [REQUIRED for BankingAgent panel to work]
# ─────────────────────────────────────────────────────────────────────────────
# Vercel does NOT support persistent WebSocket servers — the banking_mcp_server
# must run on an always-on platform.
#
# Recommended free-tier hosts:
#   • Railway   https://railway.app   (deploy banking_mcp_server)
#   • Render    https://render.com    (deploy as a Web Service)
#   • Fly.io    https://fly.io
#
# After deploying banking_mcp_server, set:
MCP_SERVER_URL=wss://<your-mcp-server-host>

# ─────────────────────────────────────────────────────────────────────────────
# SERVER CONFIG
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─────────────────────────────────────────────────────────────────────────────
# CORS  [optional — default allows the request origin]
# ─────────────────────────────────────────────────────────────────────────────
# Runtime CORS origin — set in Vercel dashboard (not in build env, which is baked into the bundle)
# Use your production deployment URL: e.g. https://banking-demo-puce.vercel.app
CORS_ORIGIN=https://banking-demo-puce.vercel.app

# ─────────────────────────────────────────────────────────────────────────────
# RFC 8693 TOKEN EXCHANGE  [optional — enables secure User Token → MCP Token flow]
# ─────────────────────────────────────────────────────────────────────────────
# When configured, the BFF performs RFC 8693 Token Exchange before every MCP tool
# call. The User Token NEVER reaches the MCP Server — only the narrowly-scoped
# MCP Token does. See the Token Exchange education panel in the app for full details.
#
# Step 1 — Create a new Client Credentials application in PingOne for the Agent:
#   PingOne → Applications → Add Application → Native/Worker
#   Grant type: Client Credentials only
#   Copy the Client ID and Client Secret below.
#
# Step 2 — Register the MCP Server as a Resource in PingOne:
#   PingOne → Resources → Add Resource
#   Audience (Resource URI): e.g. https://mcp.yourdomain.com
#   Set the same URI in banking_mcp_server as MCP_SERVER_RESOURCE_URI.
#
# Step 3 — Enable Token Exchange grant on your BFF OAuth application and configure
#   a may_act policy allowing the BFF client to exchange User Tokens.

# Agent OAuth client (Client Credentials) — represents the AI Agent as a service principal
# This is a NEW client — separate from the admin/user login clients above.
AGENT_OAUTH_CLIENT_ID=<agent-client-id>
AGENT_OAUTH_CLIENT_SECRET=<agent-client-secret>
AGENT_OAUTH_CLIENT_SCOPES=openid

# Enable the Agent as the actor_token in RFC 8693 exchanges (adds act claim to MCP Token)
USE_AGENT_ACTOR_FOR_MCP=true

# MCP Server Resource URI — the audience value the MCP Token will carry
# Must match MCP_SERVER_RESOURCE_URI in banking_mcp_server/.env
MCP_SERVER_RESOURCE_URI=https://mcp.yourdomain.com

# BFF Client ID — used to validate may_act in the User Token (must match your BFF OAuth client)
BFF_CLIENT_ID=<your-bff-client-id>
REQUIRE_MAY_ACT=false

# ─────────────────────────────────────────────────────────────────────────────
# PINGONE AUTHORIZE (optional — for policy-based transaction authorization)
# ─────────────────────────────────────────────────────────────────────────────
PINGONE_AUTHORIZE_WORKER_CLIENT_ID=
PINGONE_AUTHORIZE_WORKER_CLIENT_SECRET=
PINGONE_AUTHORIZE_POLICY_ID=

# ─────────────────────────────────────────────────────────────────────────────
# STEP-UP MFA
# ─────────────────────────────────────────────────────────────────────────────
STEP_UP_AMOUNT_THRESHOLD=250
STEP_UP_ACR_VALUE=Multi_factor

# ─────────────────────────────────────────────────────────────────────────────
# DEBUGGING  [optional — set false/omit in production]
# ─────────────────────────────────────────────────────────────────────────────
DEBUG_OAUTH=false
DEBUG_TOKENS=false
DEBUG_SCOPES=false

# ─────────────────────────────────────────────────────────────────────────────
# OAUTH CANONICAL URL (optional)
# ─────────────────────────────────────────────────────────────────────────────
# If unset on Vercel, the API uses https://banking-demo-puce.vercel.app for redirect_uri generation.
# Override if you use a custom domain. PingOne allowlist URIs: see Application Configuration in the app
# or GET /api/auth/oauth/redirect-info
# PUBLIC_APP_URL=https://banking-demo-puce.vercel.app
