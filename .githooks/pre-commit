#!/usr/bin/env bash
# .githooks/pre-commit
# Reminds you to update CHANGELOG.md, FEATURES.md, and REGRESSION_LOG.md
# before committing. Warns but does NOT block (use --no-verify to skip).

YELLOW='\033[0;33m'
CYAN='\033[0;36m'
RESET='\033[0m'

warn() { echo -e "${YELLOW}⚠  $1${RESET}"; }
info() { echo -e "${CYAN}   $1${RESET}"; }

STAGED=$(git diff --cached --name-only)
CHANGED=0

# ── CHANGELOG check ────────────────────────────────────────────────────────
if ! echo "$STAGED" | grep -q "CHANGELOG.md"; then
  warn "CHANGELOG.md not staged."
  info "Add one line under [Unreleased] in the right category (Added/Fixed/Changed/Removed)."
  CHANGED=1
fi

# ── FEATURES check (only if a route, component, service, or middleware changed) ──
FEATURE_RELEVANT=$(echo "$STAGED" | grep -E \
  "routes/|components/|services/|middleware/|mcp_server/" | grep -v "__tests__" | grep -v "\.css$")

if [ -n "$FEATURE_RELEVANT" ] && ! echo "$STAGED" | grep -q "FEATURES.md"; then
  warn "FEATURES.md not staged — but feature-related files changed:"
  echo "$FEATURE_RELEVANT" | head -5 | while read -r f; do info "$f"; done
  info "Update FEATURES.md if a feature was added, removed, or its test coverage changed."
  CHANGED=1
fi

# ── REGRESSION_LOG check (only if a test file was staged) ──────────────────
TEST_FILES=$(echo "$STAGED" | grep -E "\.test\.(js|ts)$")

if [ -n "$TEST_FILES" ] && ! echo "$STAGED" | grep -q "REGRESSION_LOG.md"; then
  warn "Test files staged but REGRESSION_LOG.md not staged."
  info "If this test covers a production bug fix, add an entry to REGRESSION_LOG.md."
  CHANGED=1
fi

# ── Summary ────────────────────────────────────────────────────────────────
if [ "$CHANGED" -eq 1 ]; then
  echo ""
  echo -e "${YELLOW}Run  git commit --no-verify  to skip these checks.${RESET}"
  echo ""
fi

# ── UI Quality Gate (BLOCKING) ───────────────────────────────────────────────
# Runs the Playwright quality suite when banking_api_ui/src/ files are staged.
# Exits 1 to block the commit if any check fails.
UI_STAGED=$(echo "$STAGED" | grep "banking_api_ui/src/")

if [ -n "$UI_STAGED" ]; then
  echo ""
  echo -e "${CYAN}🏦 UI files staged — running quality gate...${RESET}"
  echo -e "${CYAN}   (skip with: git commit --no-verify)${RESET}"
  echo ""

  UI_DIR="$(git rev-parse --show-toplevel)/banking_api_ui"
  SERVER_STARTED=0

  # Start CRA dev server if not already running
  if ! curl -sf http://127.0.0.1:3000 >/dev/null 2>&1; then
    echo "  Starting CRA dev server (one-time, ~30s)..."
    BROWSER=none PORT=3000 HOST=127.0.0.1 HTTPS=false npm --prefix "$UI_DIR" start \
      > /tmp/bxf-cra-hook.log 2>&1 &
    CRA_PID=$!
    SERVER_STARTED=1
    for i in $(seq 1 40); do
      curl -sf http://127.0.0.1:3000 >/dev/null 2>&1 && break
      sleep 3
    done
  fi

  PLAYWRIGHT_SKIP_WEBSERVER=1 npx --prefix "$UI_DIR" playwright test \
    tests/e2e/ui-quality.spec.js --reporter=list
  UI_RESULT=$?

  if [ "$SERVER_STARTED" = "1" ]; then
    kill "$CRA_PID" 2>/dev/null || true
  fi

  if [ "$UI_RESULT" -ne 0 ]; then
    echo ""
    echo -e "${YELLOW}❌ UI quality checks failed — commit blocked.${RESET}"
    echo -e "${CYAN}   Run: npm run test:e2e:score   for a full score breakdown.${RESET}"
    echo -e "${CYAN}   Docs: docs/ui-quality-criteria.md${RESET}"
    echo ""
    exit 1
  fi

  echo -e "${CYAN}✅ UI quality gate passed.${RESET}"
  echo ""
fi

exit 0
