## 2. PingOne Management API Calls

**Never hardcode URLs or credentials.** All config via `configStore.getEffective()`:

```javascript
const configStore = require('../services/configStore');
const oauthConfig = require('../config/oauth'); // lazy getters

const envId  = configStore.getEffective('pingone_environment_id');
const region = configStore.getEffective('pingone_region') || 'com';
const apiBase = `https://api.pingone.${region}/v1/environments/${envId}`;
```

### Management API Pattern (Worker app)

```javascript
async function getManagementToken() {
  const tokenUrl = `https://auth.pingone.${region}/${envId}/as/token`;
  const resp = await axios.post(tokenUrl, 'grant_type=client_credentials', {
    auth: { username: clientId, password: clientSecret },
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    timeout: 10000,
  });
  return resp.data.access_token;
}
// GET /users, POST /users, GET /users/{id}, PATCH /users/{id}
// Always timeout: 10000 on all axios calls
```

### Error Handling for PingOne Calls

```javascript
} catch (err) {
  const pingoneError = err.response?.data?.error;
  const pingoneDesc  = err.response?.data?.error_description;
  const status       = err.response?.status;
  const msg = pingoneError ? `PingOne error: ${pingoneError} — ${pingoneDesc}` : err.message;
  const wrapped = new Error(msg);
  wrapped.pingoneError = pingoneError;
  wrapped.status = status;
  throw wrapped;
}
// In routes: propagate 401/403 from PingOne; use 502 for other upstream errors
```

### Management API Scopes (Worker app)

`p1:read:user` | `p1:update:user` | `p1:update:userMfaEnabled` | `p1:create:userMfaEnabled` | `p1:delete:user`

