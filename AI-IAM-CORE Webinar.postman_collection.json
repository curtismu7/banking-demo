    {
      "name": "Lookup User with Filter Copy 3",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"UserID received\", function () {",
              "    pm.response.to.have.status(200);",
              "",
              "    response = pm.response.json();",
              "    pm.environment.set(\"userID\", response._embedded.users[0].id);",
              "    console.log(\"userID stored: \", response._embedded.users[0].id);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://api.pingone.com/v1/environments/{{envID}}/users?filter=username%20eq%20%22+passworduser+%22",
          "protocol": "https",
          "host": [
            "api",
            "pingone",
            "com"
          ],
          "path": [
            "v1",
            "environments",
            "{{envID}}",
            "users"
          ],
          "query": [
            {
              "key": "filter",
              "value": "username%20eq%20%22+passworduser+%22"
            }
          ]
        }
      },
      "response": []
    },
