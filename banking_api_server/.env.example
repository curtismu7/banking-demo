# PingOne Core (PingOne Advanced Identity Cloud) OAuth Configuration
# Copy this file to .env and replace the placeholder values with your actual configuration

# PingOne Core Tenant Configuration
# Replace 'your-tenant-name' with your actual PingOne Core tenant name
PINGONE_CORE_TENANT_NAME=

# Environment ID (PingOne Admin → Environments → (env) → Environment ID)
# Required for OAuth URLs: https://auth.pingone.{region}/{envId}/as/authorize
PINGONE_ENVIRONMENT_ID=

# Admin OAuth2 Client Configuration
# These values come from your PingOne Core OAuth2 client configuration for admin users
# PINGONE_CORE_CLIENT_ID and PINGONE_ADMIN_CLIENT_ID are equivalent (staff / BFF login)
PINGONE_CORE_CLIENT_ID=
# PINGONE_ADMIN_CLIENT_ID=
PINGONE_CORE_CLIENT_SECRET=

# Admin Redirect URI (must match what's configured in PingOne Core)
# For development, this should be: http://localhost:3001/api/auth/oauth/callback
# For production, update to your production domain
PINGONE_CORE_REDIRECT_URI=

# End User OAuth2 Client Configuration
# These values come from your PingOne Core OAuth2 client configuration for end users
PINGONE_CORE_USER_CLIENT_ID=
PINGONE_CORE_USER_CLIENT_SECRET=

# End User Redirect URI (must match what's configured in PingOne Core)
# For development, this should be: http://localhost:3001/api/auth/oauth/user/callback
# For production, update to your production domain
PINGONE_CORE_USER_REDIRECT_URI=

# Session Configuration
# Generate a strong random string for production use
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Role Configuration
# These should match the role names configured in PingOne Core
ADMIN_ROLE=
USER_ROLE=

# Server Configuration
PORT=
NODE_ENV=

# Frontend URLs for OAuth redirects
# Update these to match your frontend application URLs
FRONTEND_ADMIN_URL=
FRONTEND_DASHBOARD_URL=

# React app client URL for error redirects (and OAuth canonical origin on Vercel when PUBLIC_APP_URL unset)
REACT_APP_CLIENT_URL=

# Stable public HTTPS origin for OAuth redirect_uri on Vercel (no trailing slash).
# PingOne allows only fixed redirect URIs — each Vercel deployment has a unique hostname, so set this
# to your production alias (e.g. https://banking-demo-puce.vercel.app), NOT a per-deploy *.vercel.app URL.
# Then whitelist in PingOne exactly:
#   {PUBLIC_APP_URL}/api/auth/oauth/callback
#   {PUBLIC_APP_URL}/api/auth/oauth/user/callback
# If unset, the server uses VERCEL_PROJECT_PRODUCTION_URL (enable “Expose system env vars” in Vercel).
# To see the exact URIs this build will send: GET https://<your-app>/api/auth/oauth/redirect-info
PUBLIC_APP_URL=

# Vercel KV or Upstash Redis — when both URL and token are set, PingOne settings can be
# saved via the Config UI (SaaS). Without them on Vercel, only environment variables apply.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Optional: Debug logging for OAuth flow
# Set to 'true' to enable detailed OAuth debugging
DEBUG_OAUTH=

# Token audience configuration for client type detection (fallback)
# These audiences are used as fallback to determine if a token is for end users or AI agents
# Primary detection is now based on the "ai_agent" scope in the token
ENDUSER_AUDIENCE=
AI_AGENT_AUDIENCE=

# AI Agent scope for dynamic client registration
# Tokens with this scope are identified as AI agents
AI_AGENT_SCOPE=

# JWKS (JSON Web Key Set) rate limiting configuration
# Increase these values if you're getting "Too many requests" errors
JWKS_REQUESTS_PER_MINUTE=
JWKS_CACHE_MAX_AGE=

# Optional: Debug OAuth token information
# Set to 'true' to log detailed token information for each request
DEBUG_TOKENS=

# =
# OAUTH SCOPE CONFIGURATION
# =

# Default user type for new users (admin, customer, readonly, ai_agent)
DEFAULT_USER_TYPE=

# Scope validation settings
STRICT_SCOPE_VALIDATION=
SCOPE_VALIDATION_TIMEOUT=
CACHE_TOKEN_VALIDATION=
TOKEN_CACHE_TTL=

# Debug settings (development only)
DEBUG_SCOPES=

# =
# STEP-UP MFA
# =

# Transactions above this dollar amount trigger step-up MFA
STEP_UP_AMOUNT_THRESHOLD=250

# ACR value (acr_values) to request for step-up MFA
STEP_UP_ACR_VALUE=Multi_factor

# =
# RFC 8693 TOKEN EXCHANGE
# =
# When set, the BFF performs a token exchange before every MCP tool call.
# The user's session token is exchanged for a delegated token scoped to this
# audience, carrying `act: { client_id: <bff> }` so the MCP server can verify
# the BFF is the actor. Set to the resource URI registered in PingOne for the
# MCP server (must match MCP_SERVER_RESOURCE_URI in banking_mcp_server/.env).
MCP_SERVER_RESOURCE_URI=

# =
# CIBA — Client-Initiated Backchannel Authentication (OIDC CIBA Core 1.0)
# =
# Enables push-notification-based authentication (no browser redirect).
# Requires: PingOne app has CIBA grant type enabled + Push MFA policy configured.

# Set to true to enable the CIBA routes and UI
CIBA_ENABLED=false

# poll (server polls PingOne) or ping (PingOne calls back — requires Redis)
CIBA_TOKEN_DELIVERY_MODE=poll

# Message shown on the user's push notification
CIBA_BINDING_MESSAGE=Banking App Authentication

# Ping-mode only: the HTTPS URL PingOne will POST to when the user approves
# CIBA_NOTIFICATION_ENDPOINT=https://<your-domain>/api/auth/ciba/notify

# How often the browser polls /api/auth/ciba/poll (milliseconds)
CIBA_POLL_INTERVAL_MS=5000

# How long (seconds) a CIBA auth request stays valid before expiring
CIBA_AUTH_REQUEST_EXPIRY=300

# =
# PINGONE AUTHORIZE (optional)
# =
# Enable policy-based authorization for transactions via PingOne Authorize.
# The toggle and policy ID are configured at runtime in Admin → Security Settings.
# Worker credentials MUST be set here — they are never exposed through the admin API.

# Client credentials app with access to call PingOne Authorize evaluate endpoint
PINGONE_AUTHORIZE_WORKER_CLIENT_ID=
PINGONE_AUTHORIZE_WORKER_CLIENT_SECRET=

# PingOne Authorize policy decision point (PDP) ID — can also be set in the admin UI
PINGONE_AUTHORIZE_POLICY_ID=

# =
# MCP — Agent acts on behalf of user (RFC 8693 subject + actor)
# =
# Dedicated OAuth app (client credentials) used as actor_token; user session token is subject_token.
# Requires MCP_SERVER_RESOURCE_URI and PingOne token-exchange + may_act configuration.
# USE_AGENT_ACTOR_FOR_MCP=true
# AGENT_OAUTH_CLIENT_ID=
# AGENT_OAUTH_CLIENT_SECRET=
# AGENT_OAUTH_CLIENT_SCOPES=openid

# Optional: bootstrap PingOne directory user for the agent + mapping (custom attribute)
# PINGONE_PROVISION_AGENT_USER=true
# PINGONE_MANAGEMENT_API_TOKEN=
# PINGONE_AGENT_POPULATION_ID=
# PINGONE_AGENT_MAPPING_ATTR_NAME=bankingPrincipalUserId
# PINGONE_AGENT_USERNAME_PREFIX=banking-agent

# Optional: ROPC to re-validate credentials when binding agent identity (must enable ROPC on user app)
# PINGONE_ROPC_FOR_AGENT_BOOTSTRAP=true

# =
# Banking Agent — natural language (optional; free heuristic works without this)
# =
# Google AI (Gemini) on the API server for smarter intent routing. Get a key at https://aistudio.google.com/apikey
# If unset, POST /api/banking-agent/nl uses a built-in keyword parser (no cost).
# GEMINI_API_KEY=
# GOOGLE_AI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
