# Banking API Server — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Usage:
#   cp .env.example .env
#   Fill in the secrets (lines without a default value)
#   Start locally: npm start
#   Deploy to Vercel: vercel env add <NAME> production (or use the Vercel dashboard)
#
# PUBLIC_APP_URL is the single source of truth for OAuth redirect URIs.
#   Local:  PUBLIC_APP_URL=http://localhost:3001
#   Vercel: PUBLIC_APP_URL=https://banking-demo-puce.vercel.app
#
# NEVER commit this file with real secrets. .env is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# =============================================================================
# MCP SERVER
# =============================================================================
# WebSocket URL of the banking MCP server (local dev: ws://localhost:8080)
MCP_SERVER_URL=ws://localhost:8080

# =============================================================================
# PINGONE CONFIGURATION
# =============================================================================
# Your PingOne environment UUID — Admin → Environments → (env) → Environment ID
PINGONE_ENVIRONMENT_ID=

# Region TLD: com (default) | eu | ca | com.au | asia | sg
PINGONE_REGION=com

# =============================================================================
# ADMIN OAUTH APP  (Web Application in PingOne — staff / BFF login)
# =============================================================================
PINGONE_ADMIN_CLIENT_ID=
PINGONE_ADMIN_CLIENT_SECRET=
# Token endpoint auth method: 'basic' (default, header) | 'post' (form body)
# Must match PingOne app → Configuration → Token Endpoint Authentication Method
PINGONE_ADMIN_TOKEN_ENDPOINT_AUTH=basic

# Redirect URI: auto-derived from PUBLIC_APP_URL below — uncomment only to override.
# PINGONE_ADMIN_REDIRECT_URI=http://localhost:3001/api/auth/oauth/callback

# =============================================================================
# USER OAUTH APP  (Web Application in PingOne — end-user / customer login)
# =============================================================================
PINGONE_USER_CLIENT_ID=
PINGONE_USER_CLIENT_SECRET=

# Redirect URI: auto-derived from PUBLIC_APP_URL below — uncomment only to override.
# PINGONE_USER_REDIRECT_URI=http://localhost:3001/api/auth/oauth/user/callback

# =============================================================================
# SESSION CONFIGURATION
# =============================================================================
# Strong random secret for Express session signing.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=3001
NODE_ENV=development

# =============================================================================
# FRONTEND URLs
# =============================================================================
# UI dev server (CRA default: 3000). Proxies /api → BFF on PORT above.
REACT_APP_CLIENT_URL=http://localhost:4000
FRONTEND_ADMIN_URL=http://localhost:4000/admin
FRONTEND_DASHBOARD_URL=http://localhost:4000/dashboard

# ── PUBLIC_APP_URL ────────────────────────────────────────────────────────────
# Base URL of the BFF/API server. Drives ALL OAuth redirect URIs automatically.
#   Local:  http://localhost:3001   (must match PORT above)
#   Vercel: https://banking-demo-puce.vercel.app
# Register these in PingOne:
#   Admin redirect:  {PUBLIC_APP_URL}/api/auth/oauth/callback
#   User  redirect:  {PUBLIC_APP_URL}/api/auth/oauth/user/callback
PUBLIC_APP_URL=http://localhost:3001

# =============================================================================
# ROLE CONFIGURATION
# =============================================================================
ADMIN_ROLE=admin
USER_ROLE=customer
DEFAULT_USER_TYPE=customer

# =============================================================================
# TOKEN AUDIENCE CONFIGURATION (client-type detection)
# =============================================================================
ENDUSER_AUDIENCE=banking_api_enduser
AI_AGENT_AUDIENCE=mcp_application
AI_AGENT_SCOPE=ai_agent

# =============================================================================
# AGENT CLIENT CREDENTIALS  (Worker App in PingOne — M2M, no redirect URIs)
# =============================================================================
# Used as the actor token in RFC 8693 2-exchange delegation.
AGENT_OAUTH_CLIENT_ID=
AGENT_OAUTH_CLIENT_SECRET=
AGENT_OAUTH_CLIENT_SCOPES=openid
USE_AGENT_ACTOR_FOR_MCP=true

# AI Agent worker app (separate from AGENT_OAUTH above — used for MCP tool scopes)
AI_AGENT_CLIENT_ID=
AI_AGENT_CLIENT_SECRET=

# =============================================================================
# MCP TOKEN EXCHANGE AUDIENCES
# =============================================================================
# Resource URI registered in PingOne for the MCP server (must match MCP server config)
MCP_RESOURCE_URI=https://ai-agent.pingdemo.com
MCP_RESOURCE_URI_TWO_EXCHANGE=https://resource-server.pingdemo.com

# Audiences for gateway and agent delegation chain
AGENT_GATEWAY_AUDIENCE=https://agent-gateway.pingdemo.com
MCP_GATEWAY_AUDIENCE=https://mcp-gateway.pingdemo.com

# Enable 2-exchange RFC 8693 delegation (User → Agent → MCP)
FF_TWO_EXCHANGE_DELEGATION=true

# =============================================================================
# REDIS / UPSTASH SESSION STORE  (required for Vercel multi-instance)
# =============================================================================
# Upstash REST (preferred on Vercel — stateless HTTP, no TCP cold-start issues)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
#
# OR node-redis wire protocol (self-hosted / Railway Redis)
# REDIS_URL=
# KV_URL=

# =============================================================================
# DEBUG
# =============================================================================
DEBUG_OAUTH=true
DEBUG_TOKENS=true
DEBUG_SCOPES=true
# WARNING: Must be false in production — server exits at startup if true on Vercel
SKIP_TOKEN_SIGNATURE_VALIDATION=false

# =============================================================================
# SCOPE VALIDATION
# =============================================================================
STRICT_SCOPE_VALIDATION=false
SCOPE_VALIDATION_TIMEOUT=10000
CACHE_TOKEN_VALIDATION=true
TOKEN_CACHE_TTL=600

# JWKS rate limiting
JWKS_REQUESTS_PER_MINUTE=30
JWKS_CACHE_MAX_AGE=600000

# =============================================================================
# STEP-UP MFA
# =============================================================================
# Dollar threshold above which write operations require step-up MFA.
# Set to 0 to require step-up on ALL write operations (recommended for demos).
STEP_UP_AMOUNT_THRESHOLD=0

# ACR value to request for step-up (must match a Sign-On Policy name in PingOne).
# Leave blank to omit acr_values and rely on the app's default policy.
STEP_UP_ACR_VALUE=

# =============================================================================
# AI / LLM — Natural Language Intent Parsing
# =============================================================================
# Groq LLM for smarter intent routing. Get a key at https://console.groq.com/keys
# If unset, falls back to built-in keyword parser (no cost).
GROQ_API_KEY=

# =============================================================================
# CIBA — Client-Initiated Backchannel Authentication (OIDC CIBA Core 1.0)
# =============================================================================
# Enables push-notification-based step-up (no browser redirect).
# Requires: PingOne app has CIBA grant type enabled + Push MFA policy configured.
CIBA_ENABLED=true
CIBA_TOKEN_DELIVERY_MODE=poll
CIBA_BINDING_MESSAGE=Banking App Authentication
CIBA_POLL_INTERVAL_MS=5000
CIBA_AUTH_REQUEST_EXPIRY=300

# =============================================================================
# PINGONE AUTHORIZE  (optional — policy-based transaction authorization)
# =============================================================================
# PINGONE_AUTHORIZE_WORKER_CLIENT_ID=
# PINGONE_AUTHORIZE_WORKER_CLIENT_SECRET=
# PINGONE_AUTHORIZE_POLICY_ID=
