# =============================================================================
# banking_api_server — copy this file to .env in this directory
# =============================================================================
# Full catalog (all apps, PingOne aliases, MCP, LangChain, keys): ../.env.example
# Vercel-specific checklist: ../.env.vercel.example
# Replit: ../.env.replit.example
# =============================================================================

# PingOne Core Tenant Configuration
PINGONE_CORE_TENANT_NAME=your-tenant-name

# Admin OAuth2 Client
PINGONE_CORE_CLIENT_ID=your-admin-client-id
PINGONE_CORE_CLIENT_SECRET=your-admin-client-secret
PINGONE_CORE_REDIRECT_URI=http://localhost:3001/api/auth/oauth/callback

# End User OAuth2 Client
PINGONE_CORE_USER_CLIENT_ID=your-user-client-id
PINGONE_CORE_USER_CLIENT_SECRET=your-user-client-secret
PINGONE_CORE_USER_REDIRECT_URI=http://localhost:3001/api/auth/oauth/user/callback

# Same values under alternate names (Vercel / configStore) — use one consistent set
# PINGONE_ENVIRONMENT_ID=
# PINGONE_REGION=com
# PINGONE_AI_CORE_CLIENT_ID=
# PINGONE_AI_CORE_CLIENT_SECRET=
# PINGONE_AI_CORE_REDIRECT_URI=
# PINGONE_AI_CORE_USER_CLIENT_ID=
# PINGONE_AI_CORE_USER_CLIENT_SECRET=
# PINGONE_AI_CORE_USER_REDIRECT_URI=

SESSION_SECRET=your-session-secret-key-change-this-in-production
CONFIG_ENCRYPTION_KEY=

ADMIN_ROLE=admin
USER_ROLE=customer

PORT=3001
NODE_ENV=development

FRONTEND_ADMIN_URL=http://localhost:3000/admin
FRONTEND_DASHBOARD_URL=http://localhost:3000/dashboard
REACT_APP_CLIENT_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

DEBUG_OAUTH=false
# PINGONE_ADMIN_AUTHORIZE_PI_FLOW=false
# PINGONE_USER_AUTHORIZE_PI_FLOW=false

# PingOne Resource: Super Banking AI Agent  (audience of the Subject Token — issued at user login)
ENDUSER_AUDIENCE=https://ai-agent.pingdemo.com
# PingOne Resource: Super Banking MCP Server  (audience of the MCP Token — after RFC 8693 exchange)
AI_AGENT_AUDIENCE=https://mcp-server.pingdemo.com
AI_AGENT_SCOPE=ai_agent
# PingOne Resource: Super Banking Agent Gateway  (actor CC audience for token exchange)
AGENT_GATEWAY_AUDIENCE=https://agent-gateway.pingdemo.com

# MCP + RFC 8693
# PingOne Resource: Super Banking MCP Server  (1-exchange token audience)
# PINGONE_RESOURCE_MCP_SERVER_URI=https://mcp-server.pingdemo.com
# MCP_SERVER_URL=ws://localhost:8080

# PingOne App: Super Banking MCP Token Exchanger  (type: AI_AGENT — performs Exchange #1 / actor for 1-exchange)
# PINGONE_MCP_TOKEN_EXCHANGER_CLIENT_ID=
# PINGONE_MCP_TOKEN_EXCHANGER_CLIENT_SECRET=
# PINGONE_MCP_TOKEN_EXCHANGER_CLIENT_SCOPES=openid
# USE_AGENT_ACTOR_FOR_MCP=false

# 2-Exchange Delegated Chain (ff_two_exchange_delegation feature flag)
# Required when ff_two_exchange_delegation is ON (see Feature Flags panel)
# See docs/PINGONE_MAY_ACT_SETUP.md for PingOne config steps
# PingOne App: Super Banking AI Agent App  (type: AI_AGENT — performs Exchange #1 in 2-exchange chain)
# PINGONE_AI_AGENT_CLIENT_ID=            # Super Banking AI Agent App client ID
# PINGONE_AI_AGENT_CLIENT_SECRET=        # Super Banking AI Agent App client secret
# AI_AGENT_INTERMEDIATE_AUDIENCE=https://mcp-server.pingdemo.com  # Exchange #1 result audience
# PingOne Resource: MCP Gateway  (actor CC audience for Exchange #2)
# PINGONE_RESOURCE_MCP_GATEWAY_URI=https://mcp-gateway.pingdemo.com
# PingOne Resource: Super Banking Banking API  (Exchange #2 final token audience)
# PINGONE_RESOURCE_TWO_EXCHANGE_URI=https://resource-server.pingdemo.com
#   ↑ MUST be the *new* resource server audience — NOT the same as PINGONE_RESOURCE_MCP_SERVER_URI used in 1-exchange.
#   Using the 1-exchange MCP Server audience here causes Exchange #2 to fire the wrong `act` expression → invalid_grant.
#   Default value (https://resource-server.pingdemo.com) matches the setup guide — only override if you use a custom audience.
# BFF_CLIENT_ID=
# REQUIRE_MAY_ACT=false
# AI_AGENT_TOKEN_ENDPOINT_AUTH_METHOD=basic  # 'basic' (CLIENT_SECRET_BASIC) or 'post' (CLIENT_SECRET_POST) — must match PingOne AI Agent App setting
# MCP_EXCHANGER_TOKEN_ENDPOINT_AUTH_METHOD=basic  # 'basic' or 'post' — must match PingOne MCP Service App setting

# Live token-exchange verification (scripts) — never commit real tokens
# INTEGRATION_SUBJECT_ACCESS_TOKEN=
# RUN_PINGONE_TOKEN_INTEGRATION=true
# MCP_TOKEN_EXCHANGE_SCOPES=banking:read banking:write
# VERIFY_TOKEN_EXCHANGE_WITH_ACTOR=true
# BANKING_API_BASE_URL=http://localhost:3001
# SESSION_COOKIE=

# DISABLE_RATE_LIMIT=true

JWKS_REQUESTS_PER_MINUTE=30
JWKS_CACHE_MAX_AGE=600000
DEBUG_TOKENS=false

DEFAULT_USER_TYPE=customer
STRICT_SCOPE_VALIDATION=true
SCOPE_VALIDATION_TIMEOUT=10000
CACHE_TOKEN_VALIDATION=true
TOKEN_CACHE_TTL=600
DEBUG_SCOPES=false

CIBA_ENABLED=false
CIBA_TOKEN_DELIVERY_MODE=poll
CIBA_BINDING_MESSAGE=Banking App Authentication
CIBA_NOTIFICATION_ENDPOINT=
CIBA_AUTH_REQUEST_EXPIRY=300
CIBA_POLL_INTERVAL_MS=5000

GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

# Redis / Upstash (sessions on hosted deployments)
# REDIS_URL=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
