# =============================================================================
# banking_api_server — copy this file to .env in this directory
# =============================================================================
# Full catalog (all apps, PingOne aliases, MCP, LangChain, keys): ../.env.example
# Vercel-specific checklist: ../.env.vercel.example
# Replit: ../.env.replit.example
# =============================================================================

# PingOne Core Tenant Configuration
PINGONE_CORE_TENANT_NAME=your-tenant-name

# Admin OAuth2 Client
PINGONE_CORE_CLIENT_ID=your-admin-client-id
PINGONE_CORE_CLIENT_SECRET=your-admin-client-secret
PINGONE_CORE_REDIRECT_URI=http://localhost:3001/api/auth/oauth/callback

# End User OAuth2 Client
PINGONE_CORE_USER_CLIENT_ID=your-user-client-id
PINGONE_CORE_USER_CLIENT_SECRET=your-user-client-secret
PINGONE_CORE_USER_REDIRECT_URI=http://localhost:3001/api/auth/oauth/user/callback

# Same values under alternate names (Vercel / configStore) — use one consistent set
# PINGONE_ENVIRONMENT_ID=
# PINGONE_REGION=com
# PINGONE_AI_CORE_CLIENT_ID=
# PINGONE_AI_CORE_CLIENT_SECRET=
# PINGONE_AI_CORE_REDIRECT_URI=
# PINGONE_AI_CORE_USER_CLIENT_ID=
# PINGONE_AI_CORE_USER_CLIENT_SECRET=
# PINGONE_AI_CORE_USER_REDIRECT_URI=

SESSION_SECRET=your-session-secret-key-change-this-in-production
CONFIG_ENCRYPTION_KEY=

ADMIN_ROLE=admin
USER_ROLE=customer

PORT=3001
NODE_ENV=development

FRONTEND_ADMIN_URL=http://localhost:3000/admin
FRONTEND_DASHBOARD_URL=http://localhost:3000/dashboard
REACT_APP_CLIENT_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

DEBUG_OAUTH=false
# PINGONE_ADMIN_AUTHORIZE_PI_FLOW=false
# PINGONE_USER_AUTHORIZE_PI_FLOW=false

ENDUSER_AUDIENCE=banking_jk_enduser
AI_AGENT_AUDIENCE=banking_mcp_01_JK
AI_AGENT_SCOPE=ai_agent

# MCP + RFC 8693
# MCP_SERVER_RESOURCE_URI=https://your-mcp-resource-uri
# MCP_SERVER_URL=ws://localhost:8080
# AGENT_OAUTH_CLIENT_ID=
# AGENT_OAUTH_CLIENT_SECRET=
# AGENT_OAUTH_CLIENT_SCOPES=openid
# USE_AGENT_ACTOR_FOR_MCP=false

# 2-Exchange Delegated Chain (ff_two_exchange_delegation feature flag)
# Required when ff_two_exchange_delegation is ON (see Feature Flags panel)
# See docs/PINGONE_MAY_ACT_TWO_TOKEN_EXCHANGES.md for PingOne config steps
# AI_AGENT_CLIENT_ID=            # BX Finance AI Agent App client ID (performs Exchange #1)
# AI_AGENT_CLIENT_SECRET=        # BX Finance AI Agent App client secret
# AGENT_GATEWAY_AUDIENCE=https://agent-gateway.pingdemo.com   # AI Agent actor CC audience
# AI_AGENT_INTERMEDIATE_AUDIENCE=https://mcp-server.pingdemo.com  # Exchange #1 result audience
# MCP_GATEWAY_AUDIENCE=https://mcp-gateway.pingdemo.com       # MCP actor CC audience
# (AGENT_OAUTH_CLIENT_ID / AGENT_OAUTH_CLIENT_SECRET above = MCP Service exchanger for Exchange #2)
# BFF_CLIENT_ID=
# REQUIRE_MAY_ACT=false

# Live token-exchange verification (scripts) — never commit real tokens
# INTEGRATION_SUBJECT_ACCESS_TOKEN=
# RUN_PINGONE_TOKEN_INTEGRATION=true
# MCP_TOKEN_EXCHANGE_SCOPES=banking:read banking:write
# VERIFY_TOKEN_EXCHANGE_WITH_ACTOR=true
# BANKING_API_BASE_URL=http://localhost:3001
# SESSION_COOKIE=

# DISABLE_RATE_LIMIT=true

JWKS_REQUESTS_PER_MINUTE=30
JWKS_CACHE_MAX_AGE=600000
DEBUG_TOKENS=false

DEFAULT_USER_TYPE=customer
STRICT_SCOPE_VALIDATION=true
SCOPE_VALIDATION_TIMEOUT=10000
CACHE_TOKEN_VALIDATION=true
TOKEN_CACHE_TTL=600
DEBUG_SCOPES=false

CIBA_ENABLED=false
CIBA_TOKEN_DELIVERY_MODE=poll
CIBA_BINDING_MESSAGE=Banking App Authentication
CIBA_NOTIFICATION_ENDPOINT=
CIBA_AUTH_REQUEST_EXPIRY=300
CIBA_POLL_INTERVAL_MS=5000

GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

# Redis / Upstash (sessions on hosted deployments)
# REDIS_URL=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
