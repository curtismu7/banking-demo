# PingOne AI IAM Core OAuth Configuration
# Copy this file to .env and replace the placeholder values with your actual configuration

# PingOne Core Tenant Configuration
# Replace 'your-tenant-name' with your actual PingOne Core tenant name
PINGONE_CORE_TENANT_NAME=your-tenant-name

# Admin OAuth2 Client Configuration
# These values come from your PingOne Core OAuth2 client configuration for admin users
PINGONE_CORE_CLIENT_ID=your-admin-client-id
PINGONE_CORE_CLIENT_SECRET=your-admin-client-secret

# Admin Redirect URI (must match what's configured in PingOne Core)
# For development, this should be: http://localhost:3001/api/auth/oauth/callback
# For production, update to your production domain
PINGONE_CORE_REDIRECT_URI=http://localhost:3001/api/auth/oauth/callback

# End User OAuth2 Client Configuration
# These values come from your PingOne Core OAuth2 client configuration for end users
PINGONE_CORE_USER_CLIENT_ID=your-user-client-id
PINGONE_CORE_USER_CLIENT_SECRET=your-user-client-secret

# End User Redirect URI (must match what's configured in PingOne Core)
# For development, this should be: http://localhost:3001/api/auth/oauth/user/callback
# For production, update to your production domain
PINGONE_CORE_USER_REDIRECT_URI=http://localhost:3001/api/auth/oauth/user/callback

# Session Configuration
# Generate a strong random string for production use
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-session-secret-key-change-this-in-production

# Role Configuration
# These should match the role names configured in PingOne Core
ADMIN_ROLE=admin
USER_ROLE=customer

# Server Configuration
PORT=3001
NODE_ENV=development
# Optional: path to startup JSON seed file (in-repo data by default)
# Default: ./data/bootstrapData.json
# BANKING_BOOTSTRAP_FILE=./data/bootstrapData.json
#
# Allow POST /api/admin/bootstrap/export to write the seed file on disk (never works on Vercel).
# In production, set only if you intentionally want the admin UI "Save seed on server" to work.
# ALLOW_BOOTSTRAP_EXPORT_WRITE=true

# Frontend URLs for OAuth redirects
# Update these to match your frontend application URLs
FRONTEND_ADMIN_URL=http://localhost:3000/admin
FRONTEND_DASHBOARD_URL=http://localhost:3000/dashboard

# React app client URL for error redirects
REACT_APP_CLIENT_URL=http://localhost:3000

# Optional: Debug logging for OAuth flow
# Set to 'true' to enable detailed OAuth debugging
DEBUG_OAUTH=false

# Optional: PingOne authorize uses response_type=pi.flow and response_mode=pi.flow (per PingOne docs).
# Enable only when the corresponding PingOne OIDC app supports pi.flow / DaVinci flow policies.
# https://developer.pingidentity.com/pingone-api/auth/auth-config-options/browserless-authentication-flow-options.html
# PINGONE_ADMIN_AUTHORIZE_PI_FLOW=false
# PINGONE_USER_AUTHORIZE_PI_FLOW=false

# Token audience configuration for client type detection (fallback)
# These audiences are used as fallback to determine if a token is for end users or AI agents
# Primary detection is now based on the "ai_agent" scope in the token
ENDUSER_AUDIENCE=banking_jk_enduser
AI_AGENT_AUDIENCE=banking_mcp_01_JK

# AI Agent scope for dynamic client registration
# Tokens with this scope are identified as AI agents
AI_AGENT_SCOPE=ai_agent

# JWKS (JSON Web Key Set) rate limiting configuration
# Increase these values if you're getting "Too many requests" errors
JWKS_REQUESTS_PER_MINUTE=30
JWKS_CACHE_MAX_AGE=600000

# Optional: Debug OAuth token information
# Set to 'true' to log detailed token information for each request
DEBUG_TOKENS=false

# ============================================================================
# OAUTH SCOPE CONFIGURATION
# ============================================================================

# Default user type for new users (admin, customer, readonly, ai_agent)
DEFAULT_USER_TYPE=customer

# Scope validation settings
STRICT_SCOPE_VALIDATION=true
SCOPE_VALIDATION_TIMEOUT=10000
CACHE_TOKEN_VALIDATION=true
TOKEN_CACHE_TTL=600

# Debug settings (development only)
DEBUG_SCOPES=false

# ============================================================================
# CIBA — Client-Initiated Backchannel Authentication
# ============================================================================
# Enable push-notification-based auth (no browser redirect required)
CIBA_ENABLED=false
# Delivery mode: 'poll' (server polls) or 'ping' (PingOne calls notify endpoint)
CIBA_TOKEN_DELIVERY_MODE=poll
# Message shown on the push notification on the user's phone
CIBA_BINDING_MESSAGE=Banking App Authentication
# Ping-mode only: PingOne calls this URL when the user approves
CIBA_NOTIFICATION_ENDPOINT=
# How long the auth request remains valid (seconds)
CIBA_AUTH_REQUEST_EXPIRY=300
# Poll interval when CIBA_TOKEN_DELIVERY_MODE=poll (ms)
CIBA_POLL_INTERVAL_MS=5000

# ============================================================================
# AI / LLM — Natural Language Intent Parsing
# ============================================================================
# Priority order: Groq → Gemini → heuristic regex (no key needed)

# Groq (recommended — free tier, fast inference via llama-3.1-8b-instant)
# Get a key at: https://console.groq.com → API Keys
GROQ_API_KEY=
# Optional: override the default model
# GROQ_MODEL=llama-3.1-8b-instant

# Google Gemini (fallback if GROQ_API_KEY is not set)
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
