{
  "name": "banking-api-server",
  "version": "1.0.0",
  "description": "Simple banking API server with admin UI",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --forceExit",
    "test:unit": "jest --testPathPattern='step-up-gate|authorize-gate|runtime-settings-api|transaction-flows|demo-scenario-api' --forceExit --verbose",
    "test:auth": "jest --testPathPattern='auth|oauth-callback|oauth-error-handling|oauth-scope-integration|scope-integration' --forceExit --verbose",
    "test:all": "jest --forceExit --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --forceExit --coverage",
    "test:integration": "jest --config=jest.integration.config.js",
    "test:oauth": "./run-oauth-integration-tests.sh",
    "test:oauth-scope": "jest --testPathPattern=oauth-scope-integration.test.js --verbose --forceExit",
    "test:oauth-e2e": "jest --testPathPattern=oauth-e2e-integration.test.js --verbose --forceExit",
    "test:mcp-inspector": "jest --testPathPattern=mcp-inspector --forceExit --verbose",
    "test:bff-tokens": "jest --testPathPattern='redisWireUrl|bffSessionGating' --forceExit --verbose",
    "test:session": "jest --testPathPattern='authSession|authStateCookie|bffSessionGating|upstashSessionStore|session-store-resilience|oauth-e2e-integration' --forceExit",
    "verify:token-exchange": "node scripts/verify-token-exchange.js",
    "verify:scopes": "node scripts/verify-scope-configuration.js",
    "verify:scopes:fix": "node scripts/verify-scope-configuration.js --fix",
    "test:pingone-token-integration": "jest --testPathPattern=token-exchange-pingone --forceExit",
    "test:scope-assignments": "node test-scope-assignments.js",
    "test:oauth-provider-scopes": "node test-oauth-provider-scopes.js",
    "data:export-bootstrap": "node scripts/exportBootstrapData.js",
    "build": "echo 'API server - no build required'",
    "install-client": "cd ../banking_api_ui && npm install",
    "heroku-postbuild": "npm run install-client && npm run build"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.39",
    "@langchain/groq": "^1.2.0",
    "@langchain/langgraph": "^1.2.8",
    "@vercel/kv": "^3.0.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.3.1",
    "morgan": "^1.10.0",
    "redis": "^5.11.0",
    "uuid": "^9.0.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  },
  "keywords": [
    "banking",
    "api",
    "rest",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": "20.x",
    "npm": ">=9"
  }
}
