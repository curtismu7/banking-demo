# banking_api_ui — copy to .env (local) or set in Vercel / build host
# Full catalog: ../.env.example (REACT_APP_* must match PingOne redirect URIs)

PORT=3000
# Local dev: leave empty so axios uses same origin; src/setupProxy.js proxies /api → REACT_APP_API_PORT (default 3001)
# so session cookies match OAuth. If set to http://localhost:3001, axios still uses the proxy
# when the page is on the same host with a different port (see resolveApiBaseUrl.js).
REACT_APP_API_URL=http://localhost:3001
# Must match the URL users open in the browser and PingOne Sign Off / post-logout URIs.
# For a hosted BFF at https://api.pingdeme.org (SPA same origin), use that origin; redirect callbacks use the API host — see server oauthRedirectUris REFERENCE_REDIRECT_SETS / Config page.
REACT_APP_CLIENT_URL=http://localhost:3000
REACT_APP_ENDUSER_AUDIENCE=banking_jk_enduser
REACT_APP_AI_AGENT_AUDIENCE=banking_mcp_01_JK
# Optional: MCP inspector UI
# REACT_APP_LANGCHAIN_INSPECTOR_URL=http://localhost:8081/inspector/mcp-host
