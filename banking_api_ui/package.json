{
  "name": "banking-admin-client",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^13.3.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.4.0",
    "chart.js": "^4.3.0",
    "date-fns": "^2.30.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.28.0",
    "react-scripts": "5.0.1",
    "react-table": "^7.8.0",
    "react-toastify": "^11.0.5",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:unit": "react-scripts test --watchAll=false",
    "eject": "react-scripts eject",
    "test:e2e": "playwright test",
    "test:e2e:ci": "CI=true playwright test",
    "test:e2e:ci:reuse": "CI=true PLAYWRIGHT_SKIP_WEBSERVER=1 playwright test",
    "test:e2e:ci:vercel": "CI=true PLAYWRIGHT_BASE_URL=https://banking-demo-puce.vercel.app playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:api": "playwright test --config=playwright.api.config.js --reporter=list",
    "test:e2e:session": "playwright test tests/e2e/session-regression.spec.js --config=playwright.api.config.js --reporter=list",
    "test:e2e:admin": "playwright test tests/e2e/admin-dashboard.spec.js --reporter=list",
    "test:e2e:security": "playwright test tests/e2e/security-settings.spec.js --reporter=list",
    "test:e2e:agent": "playwright test tests/e2e/banking-agent.spec.js --reporter=list",
    "test:e2e:customer": "playwright test tests/e2e/customer-dashboard.spec.js --reporter=list",
    "test:e2e:landing": "playwright test tests/e2e/landing-marketing.spec.js --reporter=list",
    "test:e2e:ui:smoke": "playwright test tests/e2e/customer-dashboard.spec.js tests/e2e/landing-marketing.spec.js --reporter=list"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@resvg/resvg-js": "^2.6.2"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "proxy": "http://localhost:3001",
  "engines": {
    "node": "20.x",
    "npm": ">=9"
  },
  "jest": {
    "transformIgnorePatterns": [
      "/node_modules/(?!(axios)/)"
    ],
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "<rootDir>/src/__mocks__/fileMock.js"
    }
  }
}
