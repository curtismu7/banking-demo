# Real-login E2E test credentials
# Copy this file to .env.e2e and fill in your PingOne test user details.
# NEVER commit .env.e2e — it is in .gitignore.

# ── Target URL ──────────────────────────────────────────────────────────────
# Defaults to Vercel production if not set.
# Override for local or preview deployments:
#   E2E_BASE_URL=http://localhost:3000
#   E2E_BASE_URL=https://banking-demo-abc123.vercel.app
# E2E_BASE_URL=https://banking-demo-puce.vercel.app

# ── Customer test account (PingOne user with role: customer) ────────────────
E2E_CUSTOMER_USERNAME=your-test-customer@example.com
E2E_CUSTOMER_PASSWORD=YourTestPassword123!

# ── Admin test account (PingOne user with role: admin) ──────────────────────
# Optional — admin tests are skipped when these are not set.
# E2E_ADMIN_USERNAME=your-test-admin@example.com
# E2E_ADMIN_PASSWORD=YourAdminPassword123!

# ── Timing (milliseconds) ───────────────────────────────────────────────────
# Increase if your PingOne tenant is slow to load the login page
# E2E_PINGONE_LOGIN_TIMEOUT=20000

# Increase if your app takes a long time to redirect back from PingOne
# E2E_POST_LOGIN_TIMEOUT=30000
