    {
      "name": "7. User Lookup (PingOne Management API)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.collectionVariables.get('pingone_api_token')) {",
              "  throw new Error('pingone_api_token is empty — run step 6 first');",
              "}",
              "if (!pm.collectionVariables.get('user_sub')) {",
              "  throw new Error('user_sub is empty — run steps 1-4 first to decode the Subject Token');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Response is 200 OK', () => pm.response.to.have.status(200));",
              "pm.test('Response is JSON',   () => pm.response.to.be.json);",
              "",
              "const body = pm.response.json();",
              "console.log('[Step 7] User record:', JSON.stringify(body, null, 2));",
              "",
              "const expectedSub = pm.collectionVariables.get('banking_app_client_id');",
              "if (body.mayAct) {",
              "  console.log('[Step 7] mayAct:', JSON.stringify(body.mayAct));",
              "  pm.test('mayAct.sub matches banking_app_client_id', () => {",
              "    pm.expect(body.mayAct.sub).to.equal(expectedSub);",
              "  });",
              "} else {",
              "  console.warn('[Step 7] WARNING: mayAct attribute not set on user — run Utility B to set it');",
              "}"
            ]
          }
        }
