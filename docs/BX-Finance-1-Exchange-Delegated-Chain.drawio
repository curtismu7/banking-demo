    <mxCell id="2" value="BX Finance — 1-Exchange Delegated Chain (RFC 8693)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=17;fontStyle=1;" vertex="1" parent="1">
