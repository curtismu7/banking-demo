    <!-- ══════════════════════════════════════════════════════════════════ -->
    <mxCell id="301" value="&lt;b&gt;MCP Server&lt;/b&gt;&lt;br&gt;(MCP_CLIENT_ID)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
