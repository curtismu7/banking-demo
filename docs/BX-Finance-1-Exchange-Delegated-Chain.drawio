    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- STEP 1: PKCE Login — Human → BFF → PingOne → Subject Token        -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <mxCell id="101" value="&lt;b&gt;Human User&lt;/b&gt;&lt;br&gt;Browser + Banking App" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="20" y="108" width="180" height="50" as="geometry"/>
    </mxCell>
