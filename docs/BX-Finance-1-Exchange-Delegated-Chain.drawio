    <mxCell id="303" value="grant_type=client_credentials&lt;br&gt;scope: p1:read:user p1:update:user" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" source="301" target="302" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="304" value="&lt;b&gt;TOKEN 3 — PingOne API Token&lt;/b&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot; style=&quot;font-size:10px;&quot;&gt;{&lt;br&gt;&amp;nbsp;&amp;nbsp;&quot;aud&quot;:  [&quot;https://api.pingone.com&quot;],&lt;br&gt;&amp;nbsp;&amp;nbsp;&quot;scope&quot;: &quot;p1:read:user  p1:update:user&quot;&lt;br&gt;&amp;nbsp;&amp;nbsp;&lt;i&gt;// no sub — service credential, not a user token&lt;/i&gt;&lt;br&gt;}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="580" y="420" width="800" height="108" as="geometry"/>
    </mxCell>

