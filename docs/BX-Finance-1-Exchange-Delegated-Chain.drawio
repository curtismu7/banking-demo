    <mxCell id="403" value="GET /v1/environments/{envId}/users/{user_sub}&lt;br&gt;Authorization: Bearer &amp;lt;Token 3&amp;gt;  (Token 2 held separately for audit)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" source="401" target="402" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="404" value="Token 2 (MCP Token) = delegation proof. Token 3 (API Token) = PingOne credential. MCP Server validates Token 2 before investing Token 3." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f8f8;strokeColor=#cccccc;align=center;fontSize=11;" vertex="1" parent="1">
