      "description": "MCP Token audience"
    },
    {
      "key": "PINGONE_API_AUDIENCE",
      "value": "https://api.pingone.com",
      "description": "PingOne API Token audience"
    },
    {
      "key": "subject_token",
      "value": "",
      "description": "AUTO — set by Step 1 test script after PKCE login"
    },
    {
      "key": "mcp_token",
      "value": "",
      "description": "AUTO — set by Step 2"
    },
    {
      "key": "pingone_api_token",
      "value": "",
      "description": "AUTO — set by Step 3"
    },
    {
      "key": "user_sub",
      "value": "",
      "description": "AUTO — set by Step 1 (user PingOne UUID from sub claim)"
    },
    {
      "key": "auth_code",
      "value": "",
      "description": "Paste the code= value from the Step 1a browser redirect URL here before running Step 1b"
    },
    {
      "key": "pkce_code_verifier",
      "value": "",
      "description": "AUTO - generated by Step 1a pre-request"
    },
    {
      "key": "pkce_code_challenge",
      "value": "",
      "description": "AUTO - generated by Step 1a pre-request"
    },
    {
      "key": "pkce_state",
      "value": "",
      "description": "AUTO - generated by Step 1a pre-request"
    }
  ],
  "item": [
    {
      "name": "Step 1a - PKCE: Get Authorization Code (open URL in browser)",
      "request": {
        "method": "GET",
        "auth": {
          "type": "noauth"
        },
        "header": [],
        "url": {
          "raw": "https://auth.pingone.{{PINGONE_REGION}}/{{PINGONE_ENVIRONMENT_ID}}/as/authorize?client_id={{PINGONE_CORE_USER_CLIENT_ID}}&response_type=code&scope=openid%20profile%20email%20banking%3Aagent%3Ainvoke&resource={{ENDUSER_AUDIENCE}}&redirect_uri=https%3A%2F%2Foauth.pstmn.io%2Fv1%2Fcallback&code_challenge={{pkce_code_challenge}}&code_challenge_method=S256&state={{pkce_state}}",
          "protocol": "https",
          "host": [
            "auth",
            "pingone",
            "{{PINGONE_REGION}}"
          ],
          "path": [
            "{{PINGONE_ENVIRONMENT_ID}}",
            "as",
            "authorize"
          ],
          "query": [
            {
              "key": "client_id",
              "value": "{{PINGONE_CORE_USER_CLIENT_ID}}"
            },
            {
              "key": "response_type",
              "value": "code"
            },
            {
              "key": "scope",
              "value": "openid profile email banking:agent:invoke"
            },
            {
              "key": "resource",
              "value": "{{ENDUSER_AUDIENCE}}"
            },
            {
              "key": "redirect_uri",
              "value": "https://oauth.pstmn.io/v1/callback"
            },
            {
              "key": "code_challenge",
              "value": "{{pkce_code_challenge}}"
            },
            {
              "key": "code_challenge_method",
              "value": "S256"
            },
            {
              "key": "state",
              "value": "{{pkce_state}}"
            }
          ]
        },
        "description": "**Step 1 of 2 for the Subject Token.** This request:\n1. Generates a fresh PKCE `code_verifier` + `code_challenge` in the pre-request script.\n2. Sends GET `/authorize` to PingOne (returns a 302 redirect to the login page).\n3. Logs the complete authorization URL to the **Postman console**.\n\n## After running\n1. Open **View -> Show Postman Console** and copy the URL printed after `STEP 1a`.\n2. Paste it into a browser tab and log in as your test user.\n3. After login, PingOne redirects to `https://oauth.pstmn.io/v1/callback?code=XXXX&state=...`.\n4. Copy the `code` value from that URL.\n5. Open Collection Variables (gear icon -> Edit -> Variables) and paste the code into `auth_code`.\n6. Run **Step 1b** immediately — authorization codes expire in ~60 seconds.\n\n**Prerequisite:** Add `https://oauth.pstmn.io/v1/callback` as a Redirect URI on the BX Finance User app in PingOne."
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Generate PKCE code_verifier (64-char URL-safe random string per RFC 7636)",
              "const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-._~';",
              "let verifier = '';",
              "for (let i = 0; i < 64; i++) {",
              "    verifier += chars.charAt(Math.floor(Math.random() * chars.length));",
              "}",
              "pm.collectionVariables.set('pkce_code_verifier', verifier);",
              "",
              "// code_challenge = BASE64URL(SHA256(code_verifier))",
              "const wordArray = CryptoJS.SHA256(verifier);",
              "const b64       = CryptoJS.enc.Base64.stringify(wordArray);",
              "const challenge = b64.replace(/\\+/g, '-').replace(/\\//g, '_').replace(/=/g, '');",
              "pm.collectionVariables.set('pkce_code_challenge', challenge);",
              "",
              "// Random state for CSRF protection",
              "const state = Math.random().toString(36).substring(2) + Math.random().toString(36).substring(2);",
              "pm.collectionVariables.set('pkce_state', state);",
              "",
              "// Build and log the full authorization URL",
              "const env    = pm.collectionVariables.get('PINGONE_ENVIRONMENT_ID');",
              "const region = pm.collectionVariables.get('PINGONE_REGION') || 'com';",
              "const cid    = pm.collectionVariables.get('PINGONE_CORE_USER_CLIENT_ID');",
              "const aud    = pm.collectionVariables.get('ENDUSER_AUDIENCE');",
              "",
              "const authorizeUrl = `https://auth.pingone.${region}/${env}/as/authorize`",
              "    + `?client_id=${cid}`",
              "    + `&response_type=code`",
              "    + `&scope=${encodeURIComponent('openid profile email banking:agent:invoke')}`",
              "    + `&resource=${encodeURIComponent(aud)}`",
              "    + `&redirect_uri=${encodeURIComponent('https://oauth.pstmn.io/v1/callback')}`",
              "    + `&code_challenge=${encodeURIComponent(challenge)}`",
              "    + `&code_challenge_method=S256`",
              "    + `&state=${state}`;",
              "",
              "console.log('');",
              "console.log('=== STEP 1a: Open this URL in your browser ===');",
              "console.log('');",
              "console.log(authorizeUrl);",
              "console.log('');",
              "console.log('>>> After login, copy code= from the redirect URL and paste into auth_code collection variable, then run Step 1b.');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// PingOne returns 302 -> login page. Check console for the URL to open in browser.",
              "console.log('[Step 1a] PKCE params generated and saved.');",
              "console.log('[Step 1a] code_verifier:', pm.collectionVariables.get('pkce_code_verifier'));",
              "console.log('[Step 1a] code_challenge:', pm.collectionVariables.get('pkce_code_challenge'));",
              "console.log('[Step 1a] Next: paste the auth code into auth_code variable, then run Step 1b.');"
            ]
          }
        }
      ]
    },
    {
      "name": "Step 1b - PKCE: Exchange Code for Subject Token (POST /token)",
      "request": {
        "method": "POST",
        "auth": {
          "type": "noauth"
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "grant_type",
              "value": "authorization_code"
            },
            {
              "key": "client_id",
              "value": "{{PINGONE_CORE_USER_CLIENT_ID}}"
            },
            {
              "key": "code",
              "value": "{{auth_code}}",
              "description": "Paste the code from the Step 1a browser redirect into auth_code collection variable first"
            },
            {
              "key": "code_verifier",
              "value": "{{pkce_code_verifier}}",
              "description": "AUTO - generated by Step 1a pre-request"
            },
            {
              "key": "redirect_uri",
              "value": "https://oauth.pstmn.io/v1/callback"
            }
          ]
        },
        "url": {
          "raw": "https://auth.pingone.{{PINGONE_REGION}}/{{PINGONE_ENVIRONMENT_ID}}/as/token",
          "protocol": "https",
          "host": [
            "auth",
            "pingone",
            "{{PINGONE_REGION}}"
          ],
          "path": [
            "{{PINGONE_ENVIRONMENT_ID}}",
            "as",
            "token"
          ]
        },
        "description": "**Step 2 of 2 for the Subject Token.** Exchanges the PKCE authorization code for the Subject Token (Token 1).\n\n## Before sending\n1. Run **Step 1a** to generate the PKCE params and authorization URL.\n2. Open the URL from the Postman console in your browser and log in.\n3. Copy the `code=` value from the browser's redirect URL.\n4. Paste it into `auth_code` in Collection Variables.\n5. Send this request **immediately** (codes expire in ~60 seconds).\n\n## What PingOne validates\n- `code` matches the authorization code issued for this session.\n- `code_verifier` matches the `code_challenge` sent in Step 1a (PKCE proof).\n- `redirect_uri` matches the registered redirect URI.\n\n## On success, the Subject Token will have\n- `aud = https://ai-agent.pingdemo.com`\n- `may_act.sub = PINGONE_CORE_CLIENT_ID` (required for Step 2 Token Exchange)\n\nIf `invalid_grant`: the code expired or was already used. Rerun Step 1a.\nIf `may_act` is missing: run Utility - Set mayAct on User, then repeat Steps 1a + 1b to get a fresh token."
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const code = pm.collectionVariables.get('auth_code');",
              "if (!code || code.trim() === '') {",
              "    throw new Error('[Step 1b] auth_code is empty. Run Step 1a, log in, copy the code= value from the redirect URL, and paste it into the auth_code collection variable.');",
              "}",
              "const verifier = pm.collectionVariables.get('pkce_code_verifier');",
              "if (!verifier || verifier.trim() === '') {",
              "    throw new Error('[Step 1b] pkce_code_verifier is empty. Run Step 1a first to generate the PKCE params.');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Step 1b: Status 200 - token endpoint success', () => pm.response.to.have.status(200));",
              "",
              "const json = pm.response.json();",
              "if (pm.response.code !== 200) {",
              "    console.error('[Step 1b] Error:', JSON.stringify(json));",
              "    if (json.error === 'invalid_grant') {",
              "        console.error('[Step 1b] Auth code expired or already used. Rerun Step 1a and paste a fresh code into auth_code.');",
              "    }",
              "    return;",
              "}",
              "",
              "pm.test('Step 1b: access_token present', () => pm.expect(json.access_token).to.be.a('string').and.not.empty);",
              "",
              "if (json.access_token) {",
              "    pm.collectionVariables.set('subject_token', json.access_token);",
              "    pm.collectionVariables.set('auth_code', '');  // clear used code",
              "    console.log('[Step 1b] subject_token saved. auth_code cleared.');",
              "",
              "    // Decode and validate JWT claims",
              "    const parts = json.access_token.split('.');",
              "    if (parts.length === 3) {",
              "        try {",
              "            const payload = JSON.parse(atob(parts[1].replace(/-/g, '+').replace(/_/g, '/')));",
              "            console.log('[Step 1b] Subject Token claims:', JSON.stringify(payload, null, 2));",
              "",
              "            if (payload.sub) {",
              "                pm.collectionVariables.set('user_sub', payload.sub);",
              "                console.log('[Step 1b] user_sub saved:', payload.sub);",
              "            }",
              "",
              "            const aud = Array.isArray(payload.aud) ? payload.aud : [payload.aud];",
              "            pm.test('Step 1b: aud = ENDUSER_AUDIENCE (ai-agent.pingdemo.com)', () => {",
              "                pm.expect(aud).to.include(pm.collectionVariables.get('ENDUSER_AUDIENCE'));",
              "            });",
              "",
              "            pm.test('Step 1b: may_act claim present', () => {",
              "                pm.expect(payload).to.have.property('may_act');",
              "                pm.expect(payload.may_act).to.have.property('sub');",
              "            });",
              "",
              "            if (payload.may_act) {",
              "                const expectedActorId = pm.collectionVariables.get('PINGONE_CORE_CLIENT_ID');",
              "                console.log('[Step 1b] may_act.sub =', payload.may_act.sub, '| expected:', expectedActorId);",
              "                pm.test('Step 1b: may_act.sub === PINGONE_CORE_CLIENT_ID', () => {",
              "                    pm.expect(payload.may_act.sub).to.equal(expectedActorId);",
              "                });",
              "            } else {",
              "                console.warn('[Step 1b] WARNING: may_act missing. Run Utility - Set mayAct on User (needs pingone_api_token from Step 3), then repeat Steps 1a + 1b.');",
              "            }",
              "        } catch (e) {",
              "            console.error('[Step 1b] Could not decode JWT:', e.message);",
              "        }",
              "    }",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Step 2 — MCP Token (RFC 8693 Token Exchange #1)",
      "request": {
        "method": "POST",
        "auth": {
          "type": "noauth"
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "grant_type",
              "value": "urn:ietf:params:oauth:grant-type:token-exchange"
            },
            {
              "key": "client_id",
              "value": "{{PINGONE_CORE_CLIENT_ID}}"
            },
            {
              "key": "client_secret",
              "value": "{{PINGONE_CORE_CLIENT_SECRET}}"
            },
            {
              "key": "subject_token",
              "value": "{{subject_token}}",
              "description": "Subject Token from Step 1"
            },
            {
              "key": "subject_token_type",
              "value": "urn:ietf:params:oauth:token-type:access_token"
            },
            {
              "key": "requested_token_type",
              "value": "urn:ietf:params:oauth:token-type:access_token"
            },
            {
              "key": "audience",
              "value": "{{MCP_RESOURCE_URI}}",
              "description": "https://mcp-server.pingdemo.com"
            },
            {
              "key": "scope",
              "value": "banking:accounts:read banking:transactions:read banking:transactions:write"
            }
          ]
        },
        "url": {
          "raw": "https://auth.pingone.{{PINGONE_REGION}}/{{PINGONE_ENVIRONMENT_ID}}/as/token",
          "protocol": "https",
          "host": [
            "auth",
            "pingone",
            "{{PINGONE_REGION}}"
          ],
          "path": [
            "{{PINGONE_ENVIRONMENT_ID}}",
            "as",
            "token"
          ]
        },
        "description": "RFC 8693 Token Exchange #1.\n\nThe **BX Finance Banking App** (`PINGONE_CORE_CLIENT_ID`) exchanges the Subject Token for a narrower MCP-scoped token.\n\nPingOne validates:\n- `subject_token.may_act.sub` === `PINGONE_CORE_CLIENT_ID` (the Banking App's own client ID)\n\nOn success the returned MCP Token will have:\n- `aud = https://mcp-server.pingdemo.com`\n- `act.sub = PINGONE_CORE_CLIENT_ID`\n- `scope = banking:accounts:read banking:transactions:read banking:transactions:write`\n\nIf you get `invalid_grant`: the `may_act.sub` on the user's Subject Token doesn't match `PINGONE_CORE_CLIENT_ID`. Fix by setting `mayAct = { \"sub\": \"<PINGONE_CORE_CLIENT_ID>\" }` on the user record (demo app → /demo-data → Enable may_act)."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "",
              "pm.test('Step 2: Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Step 2: access_token present', () => pm.expect(json.access_token).to.be.a('string').and.not.empty);",
              "",
              "if (json.access_token) {",
              "    pm.collectionVariables.set('mcp_token', json.access_token);",
              "    console.log('[Step 2] mcp_token saved');",
              "",
              "    const parts = json.access_token.split('.');",
              "    if (parts.length === 3) {",
              "        try {",
              "            const payload = JSON.parse(atob(parts[1].replace(/-/g, '+').replace(/_/g, '/')));",
              "            console.log('[Step 2] MCP Token claims:', JSON.stringify(payload, null, 2));",
              "",
              "            // Verify audience",
              "            const aud = Array.isArray(payload.aud) ? payload.aud : [payload.aud];",
              "            pm.test('Step 2: aud = https://mcp-server.pingdemo.com', () => {",
              "                pm.expect(aud).to.include(pm.collectionVariables.get('MCP_RESOURCE_URI'));",
              "            });",
              "",
              "            // Verify act claim (delegation proof)",
              "            pm.test('Step 2: act claim present', () => {",
              "                pm.expect(payload).to.have.property('act');",
              "                pm.expect(payload.act).to.have.property('sub');",
              "            });",
              "",
              "            if (payload.act) {",
              "                const expectedActorId = pm.collectionVariables.get('PINGONE_CORE_CLIENT_ID');",
              "                console.log('[Step 2] act.sub =', payload.act.sub, '| expected:', expectedActorId);",
              "                pm.test('Step 2: act.sub === PINGONE_CORE_CLIENT_ID', () => {",
              "                    pm.expect(payload.act.sub).to.equal(expectedActorId);",
              "                });",
              "            }",
              "",
              "            // Verify sub preserved from Subject Token",
              "            const userSub = pm.collectionVariables.get('user_sub');",
              "            if (userSub) {",
              "                pm.test('Step 2: sub preserved from Subject Token', () => {",
              "                    pm.expect(payload.sub).to.equal(userSub);",
              "                });",
              "            }",
              "        } catch (e) {",
              "            console.error('[Step 2] Could not decode JWT payload:', e.message);",
              "        }",
              "    }",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Step 3 — PingOne API Token (Client Credentials)",
      "request": {
        "method": "POST",
        "auth": {
          "type": "noauth"
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "grant_type",
              "value": "client_credentials"
            },
            {
              "key": "client_id",
              "value": "{{MCP_CLIENT_ID}}"
            },
            {
              "key": "client_secret",
              "value": "{{MCP_CLIENT_SECRET}}"
            },
            {
              "key": "scope",
              "value": "p1:read:user p1:update:user"
            }
          ]
        },
        "url": {
          "raw": "https://auth.pingone.{{PINGONE_REGION}}/{{PINGONE_ENVIRONMENT_ID}}/as/token",
          "protocol": "https",
          "host": [
            "auth",
            "pingone",
            "{{PINGONE_REGION}}"
          ],
          "path": [
            "{{PINGONE_ENVIRONMENT_ID}}",
            "as",
            "token"
          ]
        },
        "description": "Client Credentials grant for **BX Finance MCP Service**.\n\nThis is NOT a token exchange. The MCP Service authenticates with its own credentials and requests a scoped token for the PingOne Management API.\n\nThe returned token will have:\n- `aud = https://api.pingone.com`\n- `scope = p1:read:user p1:update:user`\n- No `sub` (it represents the service, not a user)\n\nIf `invalid_scope`: enable `p1:read:user` and `p1:update:user` on the BX Finance MCP Service app Resources tab (Step 2c of setup guide)."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "",
              "pm.test('Step 3: Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Step 3: access_token present', () => pm.expect(json.access_token).to.be.a('string').and.not.empty);",
              "",
              "if (json.access_token) {",
              "    pm.collectionVariables.set('pingone_api_token', json.access_token);",
              "    console.log('[Step 3] pingone_api_token saved');",
              "",
              "    const parts = json.access_token.split('.');",
              "    if (parts.length === 3) {",
              "        try {",
              "            const payload = JSON.parse(atob(parts[1].replace(/-/g, '+').replace(/_/g, '/')));",
              "            console.log('[Step 3] PingOne API Token claims:', JSON.stringify(payload, null, 2));",
              "",
              "            // Verify audience",
              "            const aud = Array.isArray(payload.aud) ? payload.aud : [payload.aud];",
              "            pm.test('Step 3: aud = https://api.pingone.com', () => {",
              "                pm.expect(aud).to.include(pm.collectionVariables.get('PINGONE_API_AUDIENCE'));",
              "            });",
              "",
              "            // Verify scope",
              "            pm.test('Step 3: scope includes p1:read:user', () => {",
              "                pm.expect(payload.scope).to.include('p1:read:user');",
              "            });",
              "",
              "            // Token 3 should NOT have a sub (service token, not user token)",
              "            if (payload.sub) {",
              "                console.warn('[Step 3] Unexpected sub claim on PingOne API Token:', payload.sub);",
              "            }",
              "        } catch (e) {",
              "            console.error('[Step 3] Could not decode JWT payload:', e.message);",
              "        }",
              "    }",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Step 4 — User Lookup (PingOne Management API)",
      "request": {
        "method": "GET",
        "auth": {
          "type": "noauth"
        },
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{pingone_api_token}}"
          }
        ],
        "url": {
          "raw": "https://api.pingone.{{PINGONE_REGION}}/v1/environments/{{PINGONE_ENVIRONMENT_ID}}/users/{{user_sub}}",
          "protocol": "https",
          "host": [
            "api",
            "pingone",
            "{{PINGONE_REGION}}"
          ],
          "path": [
            "v1",
            "environments",
            "{{PINGONE_ENVIRONMENT_ID}}",
            "users",
            "{{user_sub}}"
          ]
        },
        "description": "Calls the PingOne Management API using Token 3 (PingOne API Token).\n\n`user_sub` was captured automatically in Step 1 from the Subject Token's `sub` claim.\n\nA 200 response with the user object confirms the full chain works end-to-end:\n1. User logged in → Subject Token with `may_act`\n2. Banking App exchanged → MCP Token with `act`\n3. MCP Service obtained → PingOne API Token with `p1:read:user`\n4. Management API authorized the call\n\nAlso verifies that the `mayAct` custom attribute is present on the user record."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "",
              "pm.test('Step 4: Status 200 — user lookup succeeded', () => pm.response.to.have.status(200));",
              "pm.test('Step 4: id matches user_sub', () => {",
              "    pm.expect(json.id).to.equal(pm.collectionVariables.get('user_sub'));",
              "});",
              "",
              "if (pm.response.code === 200) {",
              "    console.log('[Step 4] User object:', JSON.stringify(json, null, 2));",
              "",
              "    // Check mayAct custom attribute is set",
              "    if (json.mayAct) {",
              "        console.log('[Step 4] mayAct on user record:', JSON.stringify(json.mayAct));",
              "        pm.test('Step 4: mayAct.sub matches PINGONE_CORE_CLIENT_ID', () => {",
              "            pm.expect(json.mayAct.sub).to.equal(pm.collectionVariables.get('PINGONE_CORE_CLIENT_ID'));",
              "        });",
              "    } else {",
              "        console.warn('[Step 4] WARNING: mayAct attribute missing from user record. Token Exchange will fail at runtime. Set it via /demo-data → Enable may_act or via PATCH /users/{id}.');",
              "    }",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Utility — Decode Token (paste any JWT)",
      "request": {
        "method": "POST",
        "auth": {
          "type": "noauth"
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "token",
              "value": "{{subject_token}}",
              "description": "Replace with any of: subject_token, mcp_token, pingone_api_token"
            }
          ]
        },
        "url": {
          "raw": "https://auth.pingone.{{PINGONE_REGION}}/{{PINGONE_ENVIRONMENT_ID}}/as/introspect",
          "protocol": "https",
          "host": [
            "auth",
            "pingone",
            "{{PINGONE_REGION}}"
          ],
          "path": [
            "{{PINGONE_ENVIRONMENT_ID}}",
            "as",
            "introspect"
          ]
        },
        "description": "Introspects any saved token against PingOne's introspection endpoint.\n\nChange the `token` body value to one of:\n- `{{subject_token}}` — Token 1\n- `{{mcp_token}}` — Token 2\n- `{{pingone_api_token}}` — Token 3\n\nOr use the [PingIdentity JWT Decoder](https://developer.pingidentity.com/en/tools/jwt-decoder.html) to decode offline."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.test('Introspection returned valid response', () => pm.response.to.have.status(200));",
              "console.log('[Introspect] Result:', JSON.stringify(json, null, 2));",
              "if (json.active === false) {",
              "    console.warn('[Introspect] Token is INACTIVE or expired.');",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Utility — Set mayAct on User (PATCH)",
      "request": {
        "method": "PATCH",
        "auth": {
          "type": "noauth"
        },
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{pingone_api_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mayAct\": {\n    \"sub\": \"{{PINGONE_CORE_CLIENT_ID}}\"\n  }\n}"
        },
        "url": {
          "raw": "https://api.pingone.{{PINGONE_REGION}}/v1/environments/{{PINGONE_ENVIRONMENT_ID}}/users/{{user_sub}}",
          "protocol": "https",
          "host": [
            "api",
            "pingone",
            "{{PINGONE_REGION}}"
          ],
          "path": [
            "v1",
            "environments",
            "{{PINGONE_ENVIRONMENT_ID}}",
            "users",
            "{{user_sub}}"
          ]
        },
        "description": "Sets the `mayAct` custom attribute on the test user.\n\n**Run this if Step 1 returns a Subject Token without a `may_act` claim** (the test script will warn you).\n\nRequires Token 3 (`pingone_api_token`) in the Authorization header — run Steps 1–3 first.\n\n`PINGONE_CORE_CLIENT_ID` is the client ID UUID of **BX Finance Banking App** — the app that is authorized to exchange this user's token."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Set mayAct: Status 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "if (json.mayAct) {",
              "    console.log('[Set mayAct] Updated mayAct:', JSON.stringify(json.mayAct));",
              "    pm.test('mayAct.sub saved correctly', () => {",
              "        pm.expect(json.mayAct.sub).to.equal(pm.collectionVariables.get('PINGONE_CORE_CLIENT_ID'));",
              "    });",
              "    console.log('[Set mayAct] Now re-run Step 1 to get a fresh Subject Token with the may_act claim.');",
              "}"
            ]
          }
        }
      ]
    }
  ]
}
