        <mxCell id="secB_hdr" value="PROTOCOL VERSION NEGOTIATION (MUST + SHOULD)" style="text;html=1;strokeColor=#0d6b3e;fillColor=#0d6b3e;align=left;verticalAlign=middle;fontColor=#ffffff;fontSize=11;fontStyle=1;spacingLeft=8;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="300" width="1560" height="24" as="geometry" />
        </mxCell>
        <mxCell id="r4a" value="Server MUST echo same version if supported; else respond with own version" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="20" y="324" width="240" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r4b" value="MCP Lifecycle §version negotiation" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="270" y="324" width="200" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r4c" value="MCPMessageHandler.negotiateProtocolVersion() — supports 2025-11-25 and 2024-11-05" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="480" y="324" width="340" height="38" as="geometry" />
