  <diagram id="bff-detail" name="BFF — Compliance Detail">
    <mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bff_title" value="BFF (banking_api_server) — Compliance Detail" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="1500" height="34" as="geometry" />
        </mxCell>
        <mxCell id="bff_sub" value="Each box shows the MCP / RFC / OAuth requirement enforced by that component.  Green=MUST | Blue=SHOULD | Orange=Opt-in" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="100" y="46" width="1500" height="18" as="geometry" />
        </mxCell>
        <!-- BFF background container -->
        <mxCell id="bff_bg" value="" style="rounded=1;fillColor=#f0f4ff;strokeColor=#3c5a99;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="70" width="1660" height="950" as="geometry" />
        </mxCell>
        <!-- Row 1 -->
        <mxCell id="b_core" value="&lt;b&gt;BFF Core&lt;/b&gt; (server.js)&lt;br/&gt;Express session (Upstash Redis)&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Tokens stay server-side (BFF pattern)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Cookie-based session (HttpOnly, Secure)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: upstashSessionStore.js — cross-instance session&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: Cold-start safe — KV_REST_API_URL must be set&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="30" y="90" width="380" height="140" as="geometry" />
        </mxCell>
        <mxCell id="b_oauth_agent" value="&lt;b&gt;Agent OAuth Flow&lt;/b&gt;&lt;br/&gt;routes/oauth.js · services/oauthService.js&lt;br/&gt;services/pkceStateCookie.js&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Authorization Code + PKCE (S256) — RFC 7636&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: state (CSRF) generated + verified on callback&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: nonce generated + verified in ID token&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: RFC 8707 resource param (oauthAuthorizeResource.js)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: confidential client (client_secret_post)&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="430" y="90" width="380" height="160" as="geometry" />
        </mxCell>
        <mxCell id="b_oauth_user" value="&lt;b&gt;End-User OAuth Flow&lt;/b&gt;&lt;br/&gt;routes/oauthUser.js · services/oauthUserService.js&lt;br/&gt;services/pkceStateCookie.js&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Authorization Code + PKCE (S256) — RFC 7636&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: state + nonce — OAuth 2.1 / OIDC Core&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: RFC 8707 resource param (no mixed scopes)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: sanitizePostLoginReturnPath — open-redirect guard&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: offline_access → refresh tokens&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="830" y="90" width="380" height="160" as="geometry" />
        </mxCell>
        <mxCell id="b_ciba" value="&lt;b&gt;CIBA — Backchannel Auth&lt;/b&gt;&lt;br/&gt;routes/ciba.js · services/cibaService.js&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: User consent for high-value tool calls&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: Push notification approval (CIBA poll)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#444&quot;&gt;MAY: OTP email verify for offline consent&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: bc-authorize binding_message per session&lt;/font&gt;" style="rounded=1;fillColor=#d1ecf1;strokeColor=#0c5460;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1230" y="90" width="380" height="160" as="geometry" />
        </mxCell>
        <!-- Row 2 -->
        <mxCell id="b_middleware" value="&lt;b&gt;Middleware Chain&lt;/b&gt;&lt;br/&gt;middleware/auth.js — session-backed auth gate&lt;br/&gt;middleware/scopeEnforcement.js — scope-to-route map&lt;br/&gt;middleware/tokenIntrospection.js — PingOne introspect&lt;br/&gt;middleware/actClaimValidator.js — RFC 8693 act claim&lt;br/&gt;middleware/tokenRefresh.js — refresh on 401&lt;br/&gt;middleware/delegationAuditLogger.js — audit trail&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Every API call gated; token never in browser&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: Act claim verified on token-exchange tokens&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: Token expiry checked before trusting session&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="30" y="290" width="380" height="220" as="geometry" />
        </mxCell>
        <mxCell id="b_tokenex" value="&lt;b&gt;Token Exchange + Agent Token&lt;/b&gt;&lt;br/&gt;services/agentMcpTokenService.js&lt;br/&gt;services/agentMcpScopePolicy.js&lt;br/&gt;utils/oauthAuthorizeResource.js&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: RFC 8693 Token Exchange — on_behalf user sub&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: MCP_TOOL_SCOPES scope-to-tool policy enforced&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Scoped agent token never stored in browser&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: may_act claim enforcement (configurable)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#b8860b&quot;&gt;⚠ OPT-IN: ff_inject_may_act (demo synthetic claim)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#b8860b&quot;&gt;⚠ OPT-IN: ff_inject_audience (demo aud injection)&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="430" y="270" width="380" height="210" as="geometry" />
        </mxCell>
        <mxCell id="b_consent" value="&lt;b&gt;Consent Challenge Service&lt;/b&gt;&lt;br/&gt;services/transactionConsentChallenge.js&lt;br/&gt;services/transactionAuthorizationService.js&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Write tool calls (&gt;$500) require user confirm&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: HMAC-SHA256 OTP, timing-safe compare&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: State machine: pending→otp_pending→confirmed&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: Email OTP sent via admin credentials only&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="830" y="270" width="380" height="190" as="geometry" />
        </mxCell>
        <mxCell id="b_authorize_gate" value="&lt;b&gt;PingOne Authorize Gate&lt;/b&gt;&lt;br/&gt;services/mcpToolAuthorizationService.js&lt;br/&gt;services/simulatedAuthorizeService.js&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: First MCP tool call evaluated via policy&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: Trust Framework DecisionContext=McpFirstTool&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#444&quot;&gt;MAY: Simulated Authorize for education (no PingOne)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#b8860b&quot;&gt;⚠ Feature flag: ff_authorize_mcp_first_tool&lt;/font&gt;" style="rounded=1;fillColor=#d1ecf1;strokeColor=#0c5460;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1230" y="270" width="380" height="190" as="geometry" />
        </mxCell>
        <!-- Row 3 -->
        <mxCell id="b_wsclient" value="&lt;b&gt;MCP WebSocket Client&lt;/b&gt; (BFF side)&lt;br/&gt;services/mcpWebSocketClient.js&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: initialize (id=1) → notifications/initialized → tools/call&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: protocolVersion 2025-11-25 (configurable via Feature Flag)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: Disconnect on version mismatch (SUPPORTED_PROTOCOL_VERSIONS)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: clientInfo.description present in initialize&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Agent token passed in initialize params (not HTTP header)&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="30" y="540" width="410" height="170" as="geometry" />
        </mxCell>
        <mxCell id="b_ssehub" value="&lt;b&gt;SSE Flow Hub&lt;/b&gt;&lt;br/&gt;services/mcpFlowSseHub.js&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: SSE stream per tool call (flowTraceId)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: endTrace on res.finish / res.close&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#444&quot;&gt;MAY: Live phase timeline in AgentFlowDiagramPanel&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#444&quot;&gt;Note: Multi-instance Vercel — SSE + POST hit same Lambda only&lt;/font&gt;" style="rounded=1;fillColor=#d1ecf1;strokeColor=#0c5460;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="460" y="500" width="380" height="170" as="geometry" />
        </mxCell>
        <mxCell id="b_inspector_bff" value="&lt;b&gt;MCP Inspector Route&lt;/b&gt;&lt;br/&gt;routes/mcpInspector.js&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: GET /api/mcp/inspector/tools — no auth (local catalog)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: GET /api/mcp/inspector/context — shows runtime protocol version&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: getMcpProtocolVersion() reads Feature Flag at call time&lt;/font&gt;" style="rounded=1;fillColor=#d1ecf1;strokeColor=#0c5460;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="860" y="500" width="400" height="150" as="geometry" />
        </mxCell>
        <mxCell id="b_featureflags" value="&lt;b&gt;Feature Flags&lt;/b&gt;&lt;br/&gt;routes/featureFlags.js · services/configStore.js&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: Runtime toggles without restart:&lt;/font&gt;&lt;br/&gt;  • MCP protocol version (2025-11-25 / 2024-11-05)&lt;br/&gt;  • PingOne Authorize gate (ff_authorize_mcp_first_tool)&lt;br/&gt;  • HITL consent gate (ff_hitl_enabled)&lt;br/&gt;  • Token injection flags (ff_inject_may_act, ff_inject_audience)&lt;br/&gt;  • Step-up MFA threshold (step_up_enabled)" style="rounded=1;fillColor=#d1ecf1;strokeColor=#0c5460;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1280" y="490" width="390" height="190" as="geometry" />
        </mxCell>
        <!-- PingOne + Upstash reference row -->
        <mxCell id="b_p1_ref" value="&lt;b&gt;PingOne AS (external)&lt;/b&gt;&lt;br/&gt;Receives: authorize, token, introspect, CIBA, token-exchange&lt;br/&gt;Issues: access tokens, ID tokens, may_act / act claims" style="rounded=1;fillColor=#e8d5f5;strokeColor=#7B1FA2;strokeWidth=2;fontSize=10;whiteSpace=wrap;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="30" y="760" width="460" height="80" as="geometry" />
        </mxCell>
        <mxCell id="b_upstash_ref" value="&lt;b&gt;Upstash Redis (external)&lt;/b&gt;&lt;br/&gt;Cross-instance session, PKCE state, nonce, OAuth tokens&lt;br/&gt;Required for Vercel serverless (cold-start resilience)" style="rounded=1;fillColor=#d1ecf1;strokeColor=#0c5460;strokeWidth=2;fontSize=10;whiteSpace=wrap;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="510" y="760" width="460" height="80" as="geometry" />
        </mxCell>
        <mxCell id="b_p1_authorize_ref" value="&lt;b&gt;PingOne Authorize (external)&lt;/b&gt;&lt;br/&gt;Policy evaluation endpoint (ff_authorize_mcp_first_tool)&lt;br/&gt;Trust Framework: UserId, TokenAudience, McpResourceUri, ActClientId" style="rounded=1;fillColor=#e8d5f5;strokeColor=#7B1FA2;strokeWidth=2;fontSize=10;whiteSpace=wrap;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="990" y="760" width="460" height="80" as="geometry" />
        </mxCell>
        <!-- Arrows: BFF internals -->
        <mxCell id="ba_core_auth" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="b_core" target="b_oauth_agent">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ba_core_mid" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="b_core" target="b_middleware">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ba_tokenex_ws" value="agent token" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;fontColor=#555;rounded=0;" edge="1" parent="1" source="b_tokenex" target="b_wsclient">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ba_consent_ciba" value="push notify" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;fontColor=#555;rounded=0;" edge="1" parent="1" source="b_consent" target="b_ciba">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ba_oauth_p1" value="authorize/token" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;fontColor=#7B1FA2;rounded=0;" edge="1" parent="1" source="b_oauth_agent" target="b_p1_ref">
          <mxGeometry relative="1" as="geometry" />
