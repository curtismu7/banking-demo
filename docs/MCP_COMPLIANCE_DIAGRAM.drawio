    <!-- notifications/initialized MUST be sent -->
    <mxCell id="r2a" value="notifications/initialized MUST be sent after initialize" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="20" y="212" width="240" height="38" as="geometry" />
