        <mxCell id="ba_tokenex_p1" value="RFC 8693" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;fontColor=#7B1FA2;rounded=0;" edge="1" parent="1" source="b_tokenex" target="b_p1_ref">
