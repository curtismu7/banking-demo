    <!-- BFF main box -->
    <mxCell id="bff_box" value="&lt;b&gt;BFF Core&lt;/b&gt; (server.js)&lt;br/&gt;Express session (Upstash Redis)&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Tokens stay server-side (BFF pattern)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Cookie-based session (HttpOnly, Secure)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: upstashSessionStore.js — cross-instance session&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="30" y="330" width="310" height="130" as="geometry" />
    </mxCell>

    <!-- OAuth agent flow -->
    <mxCell id="oauth_agent_box" value="&lt;b&gt;Agent OAuth Flow&lt;/b&gt;&lt;br/&gt;routes/oauth.js · services/oauthService.js&lt;br/&gt;services/pkceStateCookie.js&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Authorization Code + PKCE (S256) — RFC 7636&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: state (CSRF) generated + verified on callback&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: nonce generated + verified in ID token&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: RFC 8707 resource param (oauthAuthorizeResource.js)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: confidential client (client_secret_post)&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="350" y="330" width="360" height="160" as="geometry" />
    </mxCell>

    <!-- OAuth user flow -->
    <mxCell id="oauth_user_box" value="&lt;b&gt;End-User OAuth Flow&lt;/b&gt;&lt;br/&gt;routes/oauthUser.js · services/oauthUserService.js&lt;br/&gt;services/pkceStateCookie.js&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Authorization Code + PKCE (S256) — RFC 7636&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: state + nonce — OAuth 2.1 / OIDC Core&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: RFC 8707 resource param (no mixed scopes)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: offline_access → refresh tokens&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="720" y="330" width="300" height="160" as="geometry" />
    </mxCell>

    <!-- Middleware stack -->
    <mxCell id="middleware_box" value="&lt;b&gt;Middleware Chain&lt;/b&gt;&lt;br/&gt;middleware/auth.js — session-backed auth gate&lt;br/&gt;middleware/scopeEnforcement.js — scope-to-route map&lt;br/&gt;middleware/tokenIntrospection.js — PingOne introspect&lt;br/&gt;middleware/actClaimValidator.js — RFC 8693 act claim&lt;br/&gt;middleware/tokenRefresh.js — refresh on 401&lt;br/&gt;middleware/delegationAuditLogger.js — audit trail&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Every API call gated; token never in browser&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: Act claim verified on token-exchange tokens&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="30" y="480" width="360" height="190" as="geometry" />
    </mxCell>

    <!-- Token Exchange / MCP Agent token service -->
    <mxCell id="tokenex_box" value="&lt;b&gt;Token Exchange + Agent Token&lt;/b&gt;&lt;br/&gt;services/agentMcpTokenService.js&lt;br/&gt;services/agentMcpScopePolicy.js&lt;br/&gt;utils/oauthAuthorizeResource.js&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: RFC 8693 Token Exchange — on_behalf user sub&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: MCP_TOOL_SCOPES scope-to-tool policy enforced&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Scoped agent token never stored in browser&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: may_act claim enforcement (configurable)&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="400" y="510" width="350" height="160" as="geometry" />
    </mxCell>

    <!-- CIBA -->
    <mxCell id="ciba_box" value="&lt;b&gt;CIBA — Backchannel Auth&lt;/b&gt;&lt;br/&gt;routes/ciba.js · services/cibaService.js&lt;br/&gt;services/cibaEnhanced.js&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: User consent for high-value tool calls&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: Push notification approval (CIBA poll)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#444&quot;&gt;MAY: OTP email verify for offline consent&lt;/font&gt;" style="rounded=1;fillColor=#d1ecf1;strokeColor=#0c5460;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="760" y="510" width="260" height="160" as="geometry" />
    </mxCell>

    <!-- MCP WebSocket Client (BFF side) -->
    <mxCell id="wsclient_box" value="&lt;b&gt;MCP WebSocket Client&lt;/b&gt; (BFF side)&lt;br/&gt;services/mcpWebSocketClient.js&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: initialize (id=1) → notifications/initialized&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: protocolVersion 2025-11-25 in clientInfo&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: Disconnect on version mismatch&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: clientInfo.description present&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Agent token passed in initialize params&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="30" y="690" width="360" height="110" as="geometry" />
    </mxCell>

    <!-- Consent challenge service -->
    <mxCell id="consent_box" value="&lt;b&gt;Consent Challenge Service&lt;/b&gt;&lt;br/&gt;services/transactionConsentChallenge.js&lt;br/&gt;services/transactionAuthorizationService.js&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Write tool calls (&gt;$500) require user confirm&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: HMAC-SHA256 OTP, timing-safe compare&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: State machine: pending→otp_pending→confirmed&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="400" y="690" width="360" height="130" as="geometry" />
    </mxCell>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
