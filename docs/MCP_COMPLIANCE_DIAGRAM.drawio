    <mxCell id="secB_hdr" value="PROTOCOL VERSION NEGOTIATION (MUST + SHOULD)" style="text;html=1;strokeColor=#0d6b3e;fillColor=#0d6b3e;align=left;verticalAlign=middle;fontColor=#ffffff;fontSize=11;fontStyle=1;spacingLeft=8;rounded=0;" vertex="1" parent="1">
