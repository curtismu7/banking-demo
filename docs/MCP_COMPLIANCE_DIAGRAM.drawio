        <mxCell id="r4d" value="✔ DONE" style="text;html=1;strokeColor=#0d6b3e;fillColor=#d4edda;align=center;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#0d6b3e;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="830" y="324" width="120" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r4e" value="Phase B. Any 2024-* client version maps to 2024-11-05." style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="960" y="324" width="620" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r5a" value="Client SHOULD disconnect on version mismatch" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="20" y="362" width="240" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r5b" value="MCP Lifecycle §disconnect on mismatch (SHOULD)" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="270" y="362" width="200" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r5c" value="mcpWebSocketClient.js — checks protocolVersion against SUPPORTED_PROTOCOL_VERSIONS; closes + rejects on mismatch" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="480" y="362" width="340" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r5d" value="✔ DONE" style="text;html=1;strokeColor=#0d6b3e;fillColor=#d4edda;align=center;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#0d6b3e;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="830" y="362" width="120" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r5e" value="Phase F. BFF (client role) disconnects; MCP server does not need to." style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="960" y="362" width="620" height="38" as="geometry" />
        </mxCell>
        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- SECTION C: JSON-RPC STRICTNESS (MUST) -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <mxCell id="secC_hdr" value="JSON-RPC PROTOCOL STRICTNESS (MUST)" style="text;html=1;strokeColor=#0d6b3e;fillColor=#0d6b3e;align=left;verticalAlign=middle;fontColor=#ffffff;fontSize=11;fontStyle=1;spacingLeft=8;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="412" width="1560" height="24" as="geometry" />
        </mxCell>
        <mxCell id="r6a" value="Request ids MUST NOT be null; MUST NOT be reused" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="20" y="436" width="240" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r6b" value="JSON-RPC 2.0 / MCP Basic §messages" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="270" y="436" width="200" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r6c" value="BankingMCPServer.isValidMCPMessage() — rejects id===null; notifications must use notifications/* without id" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="480" y="436" width="340" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r6d" value="✔ DONE" style="text;html=1;strokeColor=#0d6b3e;fillColor=#d4edda;align=center;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#0d6b3e;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="830" y="436" width="120" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r6e" value="Phase C. Id uniqueness within session enforced by sequential id counter in BFF client." style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="960" y="436" width="620" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r7a" value="Input validation failures → isError:true (not protocol errors)" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="20" y="474" width="240" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r7b" value="MCP Tools §error handling (MUST)" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="270" y="474" width="200" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r7c" value="MCPMessageHandler.handleToolCall() — unknown tool returns isError:true content block; auth failure returns −32001" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="480" y="474" width="340" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r7d" value="✔ DONE" style="text;html=1;strokeColor=#0d6b3e;fillColor=#d4edda;align=center;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#0d6b3e;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="830" y="474" width="120" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r7e" value="Phase F. LLM can self-correct on tool errors; auth gate returns protocol error correctly." style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="960" y="474" width="620" height="38" as="geometry" />
        </mxCell>
        <!-- Capability honesty -->
        <mxCell id="r8a" value="Servers MUST only advertise capabilities they implement" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="20" y="512" width="240" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r8b" value="MCP Architecture §capabilities (MUST)" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="270" y="512" width="200" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r8c" value="MCPMessageHandler.serverCapabilities — tools:{} + logging:{} only; prompts/resources omitted" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="480" y="512" width="340" height="38" as="geometry" />
