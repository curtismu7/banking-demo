    </mxCell>

    <mxCell id="r4a" value="Server MUST echo same version if supported; else respond with own version" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
