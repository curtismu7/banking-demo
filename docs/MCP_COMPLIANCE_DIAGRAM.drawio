    <!-- Banking Data (in-memory) -->
    <mxCell id="data_box" value="&lt;b&gt;Banking Data Store&lt;/b&gt;&lt;br/&gt;data/store.js (in-memory / JSON)&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#444&quot;&gt;Accounts, transactions, balances for demo&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: All mutations gated by scope + consent checks&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=2;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="1160" y="885" width="300" height="120" as="geometry" />
    </mxCell>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- ARROWS: BFF ↔ PingOne / external                                       -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <mxCell id="arr_oauth_p1" value="authorize / token" style="edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=9;fontColor=#7B1FA2;" edge="1" parent="1" source="oauth_agent_box" target="p1_as">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="arr_user_p1" value="authorize / token" style="edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=9;fontColor=#7B1FA2;" edge="1" parent="1" source="oauth_user_box" target="p1_as">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="arr_tokenex_p1" value="token exchange RFC 8693" style="edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=9;fontColor=#7B1FA2;" edge="1" parent="1" source="tokenex_box" target="p1_as">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="arr_introspect_p1" value="introspect" style="edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=9;fontColor=#7B1FA2;" edge="1" parent="1" source="introspect_box" target="p1_as">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="arr_ciba_p1" value="bc-authorize" style="edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=9;fontColor=#7B1FA2;" edge="1" parent="1" source="ciba_box" target="p1_as">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="arr_bff_upstash" value="session R/W" style="edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=9;fontColor=#0c5460;" edge="1" parent="1" source="bff_box" target="upstash_box">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="arr_tools_data" value="CRUD" style="edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=9;fontColor=#555555;" edge="1" parent="1" source="tools_box" target="data_box">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- DEFICIENCY CALLOUT BOX                                                  -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <mxCell id="deficiency_box" value="&lt;b&gt;⚠ Known Deficiency / Opt-in Items&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;b&gt;1. Token Audience Validation (MCP_SERVER_RESOURCE_URI)&lt;/b&gt;&lt;br/&gt;Code: TokenIntrospector.ts lines 89-104&lt;br/&gt;Gap: env var not set by default — aud claim NOT validated unless MCP_SERVER_RESOURCE_URI is configured&lt;br/&gt;Risk: Tokens issued for other services could be accepted in dev/demo deployments&lt;br/&gt;&lt;br/&gt;&lt;b&gt;2. Cancellation / Progress Utilities&lt;/b&gt;&lt;br/&gt;notifications/cancelled + notifications/progress not implemented&lt;br/&gt;Impact: Optional (MAY) — no client currently depends on them&lt;br/&gt;&lt;br/&gt;&lt;b&gt;3. Tasks (experimental spec feature)&lt;/b&gt;&lt;br/&gt;tasks/get, tasks/result, tasks/list, tasks/cancel not implemented&lt;br/&gt;All tools use execution.taskSupport: &apos;forbidden&apos; (default)&lt;br/&gt;&lt;br/&gt;&lt;b&gt;4. notifications/message emission&lt;/b&gt;&lt;br/&gt;logging/setLevel accepted but server never emits notifications/message (optional)" style="rounded=1;fillColor=#fff3cd;strokeColor=#b8860b;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="1480" y="860" width="900" height="290" as="geometry" />
    </mxCell>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- RFC REFERENCE PANEL                                                     -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <mxCell id="rfc_panel" value="&lt;b&gt;RFC / Standard Reference&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;RFC 6749 — OAuth 2.0 (base)&lt;br/&gt;RFC 7636 — PKCE (code_challenge S256)&lt;br/&gt;RFC 8693 — Token Exchange (on_behalf / may_act / act)&lt;br/&gt;RFC 8707 — Resource Indicators (resource= param, aud validation)&lt;br/&gt;RFC 9728 — OAuth Protected Resource Metadata (.well-known)&lt;br/&gt;RFC 6750 — Bearer Token (WWW-Authenticate, 401/403)&lt;br/&gt;OpenID Connect Core — nonce, id_token, OIDC Discovery&lt;br/&gt;OAuth 2.1 draft — no implicit, no password grant, PKCE mandatory&lt;br/&gt;RFC 5424 — Syslog (logging/setLevel level names)&lt;br/&gt;MCP Spec 2025-11-25 — lifecycle, capabilities, JSON-RPC, tools&lt;br/&gt;JSON-RPC 2.0 — id rules, error codes, notifications" style="rounded=1;fillColor=#eaf4fb;strokeColor=#1a1a2e;strokeWidth=2;fontSize=10;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="20" y="1100" width="480" height="240" as="geometry" />
    </mxCell>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- COMPLIANCE SCORE PANEL                                                  -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <mxCell id="score_panel" value="&lt;b&gt;Compliance Score Summary&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;✅ MUST (hard requirements): &lt;b&gt;ALL met&lt;/b&gt;&lt;br/&gt;  • Lifecycle: initialize, notifications/initialized, version negotiation&lt;br/&gt;  • JSON-RPC: id != null, isError:true for tool errors&lt;br/&gt;  • HTTP transport: RFC 9728, RFC 6750, MCP headers, Origin&lt;br/&gt;  • OAuth: PKCE, state, nonce, confidential client, RFC 8707 resource&lt;br/&gt;  • Capability honesty: only tools+logging advertised&lt;br/&gt;&lt;br/&gt;✅ SHOULD (recommended): &lt;b&gt;ALL met&lt;/b&gt;&lt;br/&gt;  • Disconnect on version mismatch, lifecycle gate, request timeouts&lt;br/&gt;  • 401 scope=, 403 insufficient_scope, logging/setLevel&lt;br/&gt;&lt;br/&gt;⚠️ OPT-IN: Token aud validation (MCP_SERVER_RESOURCE_URI must be set in prod)&lt;br/&gt;&lt;br/&gt;✗ NOT DONE (MAY / optional): cancellation, progress, tasks — no client needs them" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="520" y="1100" width="560" height="280" as="geometry" />
    </mxCell>

  </root>
