      <mxGeometry x="830" y="436" width="120" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r6e" value="Phase C. Id uniqueness within session enforced by sequential id counter in BFF client." style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="960" y="436" width="620" height="38" as="geometry" />
    </mxCell>

    <mxCell id="r7a" value="Input validation failures → isError:true (not protocol errors)" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="20" y="474" width="240" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r7b" value="MCP Tools §error handling (MUST)" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="270" y="474" width="200" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r7c" value="MCPMessageHandler.handleToolCall() — unknown tool returns isError:true content block; auth failure returns −32001" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="480" y="474" width="340" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r7d" value="✔ DONE" style="text;html=1;strokeColor=#0d6b3e;fillColor=#d4edda;align=center;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#0d6b3e;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="830" y="474" width="120" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r7e" value="Phase F. LLM can self-correct on tool errors; auth gate returns protocol error correctly." style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="960" y="474" width="620" height="38" as="geometry" />
    </mxCell>

    <!-- Capability honesty -->
    <mxCell id="r8a" value="Servers MUST only advertise capabilities they implement" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="20" y="512" width="240" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r8b" value="MCP Architecture §capabilities (MUST)" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="270" y="512" width="200" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r8c" value="MCPMessageHandler.serverCapabilities — tools:{} + logging:{} only; prompts/resources omitted" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="480" y="512" width="340" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r8d" value="✔ DONE" style="text;html=1;strokeColor=#0d6b3e;fillColor=#d4edda;align=center;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#0d6b3e;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="830" y="512" width="120" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r8e" value="Phase C. logging/setLevel now handled (2026-03-30); notifications/message from server is not emitted (optional)." style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="960" y="512" width="620" height="38" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- SECTION D: HTTP TRANSPORT + RFC 9728 -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <mxCell id="secD_hdr" value="HTTP TRANSPORT + AUTHORIZATION (RFC 9728, RFC 8707, RFC 6750, OAuth 2.1)" style="text;html=1;strokeColor=#0d6b3e;fillColor=#0d6b3e;align=left;verticalAlign=middle;fontColor=#ffffff;fontSize=11;fontStyle=1;spacingLeft=8;rounded=0;" vertex="1" parent="1">
      <mxGeometry x="20" y="562" width="1560" height="24" as="geometry" />
    </mxCell>

    <!-- RFC 9728 -->
    <mxCell id="r9a" value="MCP servers using HTTP MUST expose /.well-known/oauth-protected-resource" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="20" y="586" width="240" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r9b" value="RFC 9728 — OAuth Protected Resource Metadata" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="270" y="586" width="200" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r9c" value="HttpMCPTransport.ts — GET /.well-known/oauth-protected-resource  returns resource, authorization_servers, bearer_methods_supported, scopes_supported" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="480" y="586" width="340" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r9d" value="✔ DONE" style="text;html=1;strokeColor=#0d6b3e;fillColor=#d4edda;align=center;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#0d6b3e;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="830" y="586" width="120" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r9e" value="Phase D (2026-03-30). HTTP Streamable transport on same port as WebSocket." style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="960" y="586" width="620" height="38" as="geometry" />
    </mxCell>

    <!-- 401 + WWW-Authenticate + scope -->
    <mxCell id="r10a" value="MUST return 401 WWW-Authenticate on missing/invalid token; SHOULD include scope=" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="20" y="624" width="240" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r10b" value="RFC 6750 §3 Bearer Token — WWW-Authenticate; MCP Auth §401 scope (SHOULD)" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="270" y="624" width="200" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r10c" value="HttpMCPTransport.sendUnauthorized(requiredScopes?) — emits 401 with WWW-Authenticate: Bearer realm=..., resource_metadata=..., scope=&quot;...&quot;" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="480" y="624" width="340" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r10d" value="✔ DONE" style="text;html=1;strokeColor=#0d6b3e;fillColor=#d4edda;align=center;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#0d6b3e;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="830" y="624" width="120" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r10e" value="Phase D + F. scope= appended when requiredScopes known." style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="960" y="624" width="620" height="38" as="geometry" />
    </mxCell>

    <!-- 403 insufficient_scope -->
    <mxCell id="r11a" value="SHOULD return 403 insufficient_scope WWW-Authenticate on scope mismatch" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="20" y="662" width="240" height="38" as="geometry" />
