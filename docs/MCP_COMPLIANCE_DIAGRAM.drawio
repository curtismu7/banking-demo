    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- ROW 3: PingOne (external IdP)                                          -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <mxCell id="pingone_label" value="PINGONE (External Identity Provider)" style="text;html=1;fontStyle=1;fontSize=11;fillColor=none;strokeColor=none;fontColor=#7B1FA2;align=left;" vertex="1" parent="1">
      <mxGeometry x="20" y="860" width="400" height="22" as="geometry" />
    </mxCell>

    <!-- PingOne AS -->
    <mxCell id="p1_as" value="&lt;b&gt;PingOne Authorization Server&lt;/b&gt;&lt;br/&gt;/as/authorize · /as/token · /as/revoke&lt;br/&gt;/as/introspect · /.well-known/openid-configuration&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#7B1FA2&quot;&gt;Issues: access tokens, ID tokens, refresh tokens&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Provides OIDC Discovery (OpenID Connect 1.0 + RFC 9728)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: RFC 8693 Token Exchange endpoint (/as/token)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: CIBA backchannel auth (/as/bc-authorize)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: OAuth 2.1 — emits may_act, act claims&lt;/font&gt;" style="rounded=1;fillColor=#e8d5f5;strokeColor=#7B1FA2;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="20" y="885" width="440" height="200" as="geometry" />
    </mxCell>

    <!-- PingOne Management API -->
    <mxCell id="p1_mgmt" value="&lt;b&gt;PingOne Management API&lt;/b&gt;&lt;br/&gt;/v1/environments/{id}/users&lt;br/&gt;/v1/environments/{id}/mfaDevices&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#7B1FA2&quot;&gt;User profile reads + MFA enrollment&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: Scoped worker app credentials (p1:read:user)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#7B1FA2&quot;&gt;pingOneUserLookupService.js · pingOneAgentUserService.js&lt;/font&gt;" style="rounded=1;fillColor=#e8d5f5;strokeColor=#7B1FA2;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="480" y="885" width="340" height="160" as="geometry" />
    </mxCell>

    <!-- Upstash Redis -->
    <mxCell id="upstash_box" value="&lt;b&gt;Upstash Redis&lt;/b&gt;&lt;br/&gt;services/upstashSessionStore.js&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: Cross-instance session (Vercel serverless)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: PKCE state + nonce survive instance restarts&lt;/font&gt;" style="rounded=1;fillColor=#d1ecf1;strokeColor=#0c5460;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="840" y="885" width="300" height="130" as="geometry" />
