          <mxGeometry x="270" y="174" width="200" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r1c" value="mcpWebSocketClient.js — sends initialize(id=1) before any tool call" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
