    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- ROW 2: MCP SERVER (banking_mcp_server) — right column                 -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <mxCell id="mcp_label" value="MCP SERVER — banking_mcp_server (TypeScript, port 8080)" style="text;html=1;fontStyle=1;fontSize=11;fillColor=none;strokeColor=none;fontColor=#1a1a2e;align=left;" vertex="1" parent="1">
      <mxGeometry x="1060" y="290" width="700" height="22" as="geometry" />
    </mxCell>
    <mxCell id="mcp_bg" value="" style="rounded=1;fillColor=#f4f0ff;strokeColor=#512DA8;strokeWidth=2;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="1060" y="312" width="1320" height="500" as="geometry" />
    </mxCell>

    <!-- HTTP MCP Transport box -->
    <mxCell id="mcp_transport_box" value="&lt;b&gt;HttpMCPTransport.ts&lt;/b&gt;&lt;br/&gt;POST /mcp (Streamable HTTP)&lt;br/&gt;GET /.well-known/oauth-protected-resource&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: RFC 9728 — .well-known returns resource, AS, scopes&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: 401 WWW-Authenticate + scope= (RFC 6750)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: 403 insufficient_scope (RFC 6750)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: MCP-Session-Id issued on initialize&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: MCP-Protocol-Version header validated&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Origin header validated vs MCP_ALLOWED_ORIGINS&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="1070" y="330" width="380" height="210" as="geometry" />
    </mxCell>

    <!-- BankingMCPServer.ts -->
    <mxCell id="mcp_server_box" value="&lt;b&gt;BankingMCPServer.ts&lt;/b&gt;&lt;br/&gt;WebSocket JSON-RPC server&lt;br/&gt;routeMessage() · isValidMCPMessage()&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: JSON-RPC id MUST NOT be null (rejects)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: Lifecycle gate — rejects pre-initialized requests (−32600)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: notifications/* must have no id field&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: connection.initialized flag gating&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="1460" y="330" width="380" height="170" as="geometry" />
    </mxCell>

    <!-- MCPMessageHandler.ts -->
    <mxCell id="msg_handler_box" value="&lt;b&gt;MCPMessageHandler.ts&lt;/b&gt;&lt;br/&gt;handleMessage() dispatch switch&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: initialize — version negotiation (2025-11-25, 2024-11-05)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: notifications/initialized — null response (no id)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: ping → {} result&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: logging/setLevel — RFC 5424 validation, clientLogLevel stored&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: tools/list · tools/call&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: isError:true for input validation errors&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: TOOL_CALL_TIMEOUT_MS (30s, Promise.race)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: capabilities advertised = capabilities implemented&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="1070" y="560" width="430" height="230" as="geometry" />
    </mxCell>

    <!-- TokenIntrospector.ts -->
    <mxCell id="introspect_box" value="&lt;b&gt;TokenIntrospector.ts&lt;/b&gt;&lt;br/&gt;BankingAuthenticationManager.ts&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: PingOne token introspection on every call&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: active=false → AuthenticationError −32001&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#b8860b&quot;&gt;⚠ OPT-IN: RFC 8707 aud validation — requires MCP_SERVER_RESOURCE_URI set&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: may_act enforcement (REQUIRE_MAY_ACT=true)&lt;/font&gt;" style="rounded=1;fillColor=#fff3cd;strokeColor=#b8860b;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="1510" y="520" width="360" height="160" as="geometry" />
    </mxCell>

    <!-- BankingToolProvider / Registry -->
    <mxCell id="tools_box" value="&lt;b&gt;BankingToolProvider.ts · BankingToolRegistry.ts&lt;/b&gt;&lt;br/&gt;BankingToolValidator.ts · AuthorizationChallengeHandler.ts&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: tools/list returns inputSchema (JSON Schema 2020-12)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: tools/call validates args → isError:true on bad input&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Per-tool requiredScopes checked before execution&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Write tools (&gt;$500) → authChallenge → CIBA/OTP&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#444&quot;&gt;MAY: ToolDefinition carries title, annotations, execution.taskSupport&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="1070" y="800" width="460" height="170" as="geometry" />
    </mxCell>

    <!-- Storage layer (MCP) -->
    <mxCell id="mcp_storage_box" value="&lt;b&gt;Storage / Session&lt;/b&gt;&lt;br/&gt;BankingSessionManager.ts&lt;br/&gt;EncryptedTokenStorage.ts · TokenCache.ts&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Agent token stored encrypted (ENCRYPTION_KEY)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: Session TTL, cleanup interval background task&lt;/font&gt;" style="rounded=1;fillColor=#d1ecf1;strokeColor=#0c5460;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="1550" y="700" width="320" height="160" as="geometry" />
