    </mxCell>

    <mxCell id="r6a" value="Request ids MUST NOT be null; MUST NOT be reused" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="20" y="436" width="240" height="38" as="geometry" />
