  <diagram id="mcp-detail" name="MCP Server — Compliance Detail">
    <mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="mcp_title" value="MCP Server (banking_mcp_server) — Compliance Detail" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="1600" height="34" as="geometry" />
        </mxCell>
        <mxCell id="mcp_sub" value="Each box shows MCP spec 2025-11-25 requirement enforced by that TypeScript class.  Green=MUST | Blue=SHOULD | Orange=Opt-in ⚠" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="100" y="46" width="1600" height="18" as="geometry" />
        </mxCell>
        <!-- MCP background container -->
        <mxCell id="mcp_bg" value="" style="rounded=1;fillColor=#f4f0ff;strokeColor=#512DA8;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="70" width="1760" height="980" as="geometry" />
        </mxCell>
        <!-- Row 1: HTTP Transport + BankingMCPServer -->
        <mxCell id="m_httptransport" value="&lt;b&gt;HttpMCPTransport.ts&lt;/b&gt; (Phase D — HTTP Streamable)&lt;br/&gt;POST /mcp · GET /mcp (405) · DELETE /mcp&lt;br/&gt;GET /.well-known/oauth-protected-resource&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: RFC 9728 — .well-known returns resource, AS, scopes&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: 401 WWW-Authenticate w/ resource_metadata URL&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: scope= in WWW-Authenticate on 401 (RFC 6750)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: 403 insufficient_scope with scope in WWW-Authenticate&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: MCP-Session-Id UUID issued on initialize&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: MCP-Protocol-Version header required on non-init requests&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Origin header validated vs MCP_ALLOWED_ORIGINS (DNS rebind guard)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: 404 on unknown MCP-Session-Id&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Notifications return 202 (no response body)&lt;/font&gt;&lt;br/&gt;Opt-out: HTTP_MCP_TRANSPORT_ENABLED=false" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="30" y="90" width="520" height="290" as="geometry" />
        </mxCell>
        <mxCell id="m_mcpserver" value="&lt;b&gt;BankingMCPServer.ts&lt;/b&gt;&lt;br/&gt;WebSocket JSON-RPC server (port 8080)&lt;br/&gt;routeMessage() · isValidMCPMessage()&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: JSON-RPC request id MUST NOT be null (isValidMCPMessage rejects)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: notifications/* MUST NOT include id field&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: connection.initialized flag gating (routeMessage)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: Lifecycle gate — rejects pre-initialized requests (−32600)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: ping always permitted even before initialized&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: WS + HTTP share same BankingSessionManager&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: handleHttpRequest delegates to HttpMCPTransport&lt;/font&gt;" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="570" y="90" width="480" height="240" as="geometry" />
        </mxCell>
        <!-- Row 2: MCPMessageHandler + TokenIntrospector -->
        <mxCell id="m_msghandler" value="&lt;b&gt;MCPMessageHandler.ts&lt;/b&gt;&lt;br/&gt;handleMessage() dispatch switch&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: initialize — version negotiation (2025-11-25, 2024-11-05)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: notifications/initialized — null response, no JSON-RPC id&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: ping → {} result&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: logging/setLevel — RFC 5424 level validation, clientLogLevel stored&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: tools/list returns inputSchema with JSON Schema 2020-12&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: tools/call — isError:true for input validation errors (not −32602)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: capabilities advertised = capabilities implemented (tools + logging)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: TOOL_CALL_TIMEOUT_MS (default 30s, Promise.race) — configurable&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: Timeout → isError:true (LLM can self-correct)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Auth failure (no token/session) → −32001 protocol error&lt;/font&gt;&lt;br/&gt;CIBA polling path: waits for user approval, re-executes tool" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="30" y="410" width="540" height="310" as="geometry" />
        </mxCell>
        <mxCell id="m_introspector" value="&lt;b&gt;TokenIntrospector.ts&lt;/b&gt;&lt;br/&gt;BankingAuthenticationManager.ts&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: PingOne token introspection on every call&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: active=false → AuthenticationError −32001&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: MCP_EXPECTED_ACT_CLIENT_ID — act.client_id validation when set&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: may_act enforcement — MCP_EXPECTED_ACT_SUB + act.client_id&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#b8860b&quot;&gt;⚠ OPT-IN: RFC 8707 aud validation — requires MCP_SERVER_RESOURCE_URI set&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#b8860b&quot;&gt;  Risk: tokens for other services accepted if env var not set in prod&lt;/font&gt;&lt;br/&gt;Token cache: TokenCache.ts avoids redundant introspection calls" style="rounded=1;fillColor=#fff3cd;strokeColor=#b8860b;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="590" y="360" width="470" height="220" as="geometry" />
        </mxCell>
        <!-- Row 3: ToolProvider + Storage + AuthManager -->
        <mxCell id="m_toolprovider" value="&lt;b&gt;BankingToolProvider.ts · BankingToolRegistry.ts&lt;/b&gt;&lt;br/&gt;BankingToolValidator.ts · AuthorizationChallengeHandler.ts&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: tools/list returns inputSchema (JSON Schema 2020-12 per 2025-11-25 spec)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: tools/call validates args → isError:true on bad input (not −32602)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Per-tool requiredScopes checked before execution&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Write tools (&gt;$500) → authChallenge → CIBA/OTP via MCPMessageHandler&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#444&quot;&gt;MAY: ToolDefinition carries title, annotations (2025-11-25 optional fields)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#444&quot;&gt;MAY: outputSchema / structuredContent — not yet implemented&lt;/font&gt;&lt;br/&gt;Tools: get_my_accounts, get_account_balance, get_my_transactions,&lt;br/&gt;create_transfer, create_deposit, create_withdrawal, agent_identity_check" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="30" y="750" width="550" height="240" as="geometry" />
        </mxCell>
        <mxCell id="m_storage" value="&lt;b&gt;Session + Token Storage&lt;/b&gt;&lt;br/&gt;BankingSessionManager.ts&lt;br/&gt;EncryptedTokenStorage.ts · TokenCache.ts&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Agent token stored encrypted (ENCRYPTION_KEY env var)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: Session TTL (sessionTimeout config), background cleanup&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: Introspection cache (TokenCache) — avoids per-call PingOne round-trips&lt;/font&gt;&lt;br/&gt;Shared across WebSocket + HTTP transport (same BankingSessionManager)" style="rounded=1;fillColor=#d1ecf1;strokeColor=#0c5460;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="600" y="610" width="480" height="190" as="geometry" />
        </mxCell>
        <mxCell id="m_authmanager" value="&lt;b&gt;AuthorizationManager.ts&lt;/b&gt;&lt;br/&gt;AuthorizationRequestGenerator.ts&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#0d6b3e&quot;&gt;MUST: Generate PingOne PKCE auth URL for user step-up&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#0c5460&quot;&gt;SHOULD: State cookie per-request (PKCE + nonce)&lt;/font&gt;&lt;br/&gt;Used when tool needs fresh user tokens (CIBA not available)" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="600" y="825" width="460" height="150" as="geometry" />
        </mxCell>
        <!-- PingOne reference row -->
        <mxCell id="m_p1_ref" value="&lt;b&gt;PingOne AS (external)&lt;/b&gt;&lt;br/&gt;Introspection endpoint · Token Exchange · CIBA bc-authorize&lt;br/&gt;Issues: access tokens bearing may_act / act claims" style="rounded=1;fillColor=#e8d5f5;strokeColor=#7B1FA2;strokeWidth=2;fontSize=10;whiteSpace=wrap;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="30" y="1020" width="500" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m_banking_data" value="&lt;b&gt;Banking Data Store (BFF side)&lt;/b&gt;&lt;br/&gt;Accessed via HTTP by BankingAPIClient.ts&lt;br/&gt;Accounts · Transactions · Balances — all mutations scope+consent gated" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=2;fontSize=10;whiteSpace=wrap;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="560" y="1020" width="500" height="80" as="geometry" />
        </mxCell>
        <!-- Arrows -->
        <mxCell id="ma_http_handler" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="m_httptransport" target="m_msghandler">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ma_srv_handler" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="m_mcpserver" target="m_msghandler">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ma_handler_introspect" value="validate token" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;fontColor=#b8860b;rounded=0;" edge="1" parent="1" source="m_msghandler" target="m_introspector">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ma_handler_tools" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="m_msghandler" target="m_toolprovider">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ma_handler_storage" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="m_msghandler" target="m_storage">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ma_introspect_p1" value="introspect" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;fontColor=#7B1FA2;rounded=0;" edge="1" parent="1" source="m_introspector" target="m_p1_ref">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ma_tools_data" value="CRUD via BankingAPIClient" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;fontColor=#555;rounded=0;" edge="1" parent="1" source="m_toolprovider" target="m_banking_data">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="compliance-summary" name="Compliance Summary">
    <mxGraphModel dx="2063" dy="1117" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="cs_title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#1a1a2e;" value="MCP Spec 2025-11-25 — Compliance Summary" vertex="1">
          <mxGeometry height="34" width="1500" x="100" y="10" as="geometry" />
        </mxCell>
        <mxCell id="cs_sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#444444;" value="Deficiencies · RFC reference · Overall compliance score · Test coverage" vertex="1">
          <mxGeometry height="18" width="1500" x="100" y="46" as="geometry" />
        </mxCell>
        <mxCell id="cs_score" parent="1" style="rounded=1;fillColor=#d4edda;strokeColor=#0d6b3e;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;whiteSpace=wrap;" value="&lt;b&gt;Compliance Score Summary&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;✅ MUST (hard requirements): &lt;b&gt;ALL met&lt;/b&gt;&lt;br/&gt;  • Lifecycle: initialize, notifications/initialized, version negotiation&lt;br/&gt;  • JSON-RPC: id != null, isError:true for tool errors, error codes&lt;br/&gt;  • HTTP transport: RFC 9728, RFC 6750 401/403, MCP headers, Origin guard&lt;br/&gt;  • OAuth: PKCE S256, state, nonce, confidential client, RFC 8707 resource&lt;br/&gt;  • Capability honesty: only tools+logging advertised and implemented&lt;br/&gt;  • Token security: server-side only, introspection per call, encrypted storage&lt;br/&gt;&lt;br/&gt;✅ SHOULD (recommended): &lt;b&gt;ALL met&lt;/b&gt;&lt;br/&gt;  • Lifecycle gate (pre-init rejection −32600)&lt;br/&gt;  • Disconnect on protocol version mismatch&lt;br/&gt;  • Request timeouts (TOOL_CALL_TIMEOUT_MS, isError:true on timeout)&lt;br/&gt;  • 401 scope=, 403 insufficient_scope per RFC 6750&lt;br/&gt;  • logging/setLevel — RFC 5424 level validation&lt;br/&gt;  • Cross-instance session (Upstash Redis)&lt;br/&gt;&lt;br/&gt;⚠️ OPT-IN (deployed default is off):&lt;br/&gt;  • Token audience validation — set MCP_SERVER_RESOURCE_URI in production&lt;br/&gt;  • Demo synthetic injection flags — disable for production&lt;br/&gt;&lt;br/&gt;✗ NOT DONE (MAY / optional — no client currently needs them):&lt;br/&gt;  • Cancellation (notifications/cancelled)&lt;br/&gt;  • Progress (notifications/progress)&lt;br/&gt;  • Tasks (tasks/get, tasks/result, tasks/list, tasks/cancel)&lt;br/&gt;  • outputSchema / structuredContent&lt;br/&gt;  • audio / resource_link content types&lt;br/&gt;  • Server-emitted notifications/message (logging)" vertex="1">
          <mxGeometry height="540" width="560" x="20" y="70" as="geometry" />
        </mxCell>
        <mxCell id="cs_deficiency" parent="1" style="rounded=1;fillColor=#fff3cd;strokeColor=#b8860b;strokeWidth=3;fontSize=10;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;whiteSpace=wrap;" value="&lt;b&gt;⚠ Known Deficiency / Opt-in Items&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;b&gt;1. Token Audience Validation (MCP_SERVER_RESOURCE_URI)&lt;/b&gt;&lt;br/&gt;Code: TokenIntrospector.ts lines 89-104&lt;br/&gt;Gap: env var not set by default — aud claim NOT validated unless MCP_SERVER_RESOURCE_URI is configured.&lt;br/&gt;Risk: Tokens issued for other services could be accepted in dev/demo deployments.&lt;br/&gt;Fix: Set MCP_SERVER_RESOURCE_URI=$MCP_RESOURCE_URL in production environment.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;2. Cancellation / Progress Utilities&lt;/b&gt;&lt;br/&gt;notifications/cancelled + notifications/progress not implemented.&lt;br/&gt;Impact: Optional (MAY) — no client currently depends on them.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;3. Tasks (experimental 2025-11-25 feature)&lt;/b&gt;&lt;br/&gt;tasks/get, tasks/result, tasks/list, tasks/cancel not implemented.&lt;br/&gt;All tools use execution.taskSupport: &#39;forbidden&#39; (spec default).&lt;br/&gt;Impact: Optional / experimental — no client needs them yet.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;4. notifications/message emission&lt;/b&gt;&lt;br/&gt;logging/setLevel accepted + level stored, but server never pushes&lt;br/&gt;notifications/message to client (optional — no client needs it currently).&lt;br/&gt;&lt;br/&gt;&lt;b&gt;5. outputSchema / structuredContent / audio / resource_link&lt;/b&gt;&lt;br/&gt;2025-11-25 optional tool result field extensions not yet implemented.&lt;br/&gt;Impact: No LLM client currently requests them." vertex="1">
          <mxGeometry height="560" width="620" x="600" y="70" as="geometry" />
        </mxCell>
        <mxCell id="cs_rfc" parent="1" style="rounded=1;fillColor=#eaf4fb;strokeColor=#1a1a2e;strokeWidth=2;fontSize=10;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;whiteSpace=wrap;" value="&lt;b&gt;RFC / Standard Reference&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;RFC 2119 / BCP 14 — MUST, SHOULD, MAY normative language&lt;br/&gt;RFC 6749 — OAuth 2.0 (base framework)&lt;br/&gt;RFC 6750 — Bearer Token Usage (WWW-Authenticate, 401, 403)&lt;br/&gt;RFC 7636 — PKCE (code_challenge S256)&lt;br/&gt;RFC 8693 — Token Exchange (on_behalf / may_act / act claims)&lt;br/&gt;RFC 8707 — Resource Indicators (resource= param, aud validation)&lt;br/&gt;RFC 9728 — OAuth Protected Resource Metadata (.well-known)&lt;br/&gt;RFC 5424 — Syslog severity levels (logging/setLevel names)&lt;br/&gt;OpenID Connect Core 1.0 — nonce, id_token, OIDC Discovery&lt;br/&gt;OAuth 2.1 draft — no implicit, no plain PKCE, PKCE mandatory&lt;br/&gt;JSON-RPC 2.0 — id rules, error codes, notifications&lt;br/&gt;MCP Spec 2025-11-25 — lifecycle, capabilities, JSON-RPC, tools&lt;br/&gt;  Lifecycle: modelcontextprotocol.io/specification/2025-11-25/basic/lifecycle&lt;br/&gt;  Authorization: modelcontextprotocol.io/specification/2025-11-25/basic/authorization&lt;br/&gt;  Transports: modelcontextprotocol.io/specification/2025-11-25/basic/transports&lt;br/&gt;  Tools: modelcontextprotocol.io/specification/2025-11-25/server/tools&lt;br/&gt;JSON Schema 2020-12 — tool inputSchema dialect (spec default)" vertex="1">
          <mxGeometry height="420" width="440" x="1240" y="70" as="geometry" />
        </mxCell>
        <mxCell id="cs_tests" parent="1" style="rounded=1;fillColor=#d1ecf1;strokeColor=#0c5460;strokeWidth=2;fontSize=10;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;whiteSpace=wrap;" value="&lt;b&gt;Test Coverage (banking_mcp_server)&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Total: 726 passed, 0 failed, 5 skipped&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;MCPMessageHandler.test.ts — handshake, tools, lifecycle,&lt;br/&gt;  logging/setLevel (all 8 RFC 5424 levels), tool timeout&lt;br/&gt;BankingMCPServer.test.ts — server lifecycle, connections,&lt;br/&gt;  lifecycle gate (pre-init −32600, post-init pass, ping ok)&lt;br/&gt;HttpMCPTransport.test.ts — RFC 9728 metadata, 401 bearer,&lt;br/&gt;  session management, MCP-Session-Id, MCP-Protocol-Version,&lt;br/&gt;  DELETE, GET 405, origin 403, insufficient_scope 403, 202&lt;br/&gt;mcp-protocol.integration.test.ts — full lifecycle E2E&lt;br/&gt;TokenIntrospector.test.ts — may_act, act.client_id, aud&lt;br/&gt;BankingToolProvider/Registry/Validator — tool execution&lt;br/&gt;AuthorizationManager — PKCE, CIBA flows&lt;br/&gt;BankingSessionManager — TTL, encryption, cleanup&lt;br/&gt;&lt;br/&gt;Run: cd banking_mcp_server &amp;amp;&amp;amp; CI=true npm test --forceExit" vertex="1">
          <mxGeometry height="300" width="440" x="1240" y="510" as="geometry" />
        </mxCell>
        <mxCell id="cs_options" parent="1" style="rounded=1;fillColor=#fff8e1;strokeColor=#e6a817;strokeWidth=2;fontSize=10;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;whiteSpace=wrap;" value="&lt;b&gt;User-Facing Options (Admin Feature Flags)&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Admin → Feature Flags → &lt;b&gt;MCP Server&lt;/b&gt;&lt;br/&gt;  • MCP protocol version: 2025-11-25 (default) or 2024-11-05 (legacy)&lt;br/&gt;&lt;br/&gt;Admin → Feature Flags → &lt;b&gt;Token Exchange&lt;/b&gt;&lt;br/&gt;  • Auto-inject may_act (demo synthetic — off in prod)&lt;br/&gt;  • Auto-inject audience (demo synthetic — off in prod)&lt;br/&gt;&lt;br/&gt;Admin → Feature Flags → &lt;b&gt;PingOne Authorize&lt;/b&gt;&lt;br/&gt;  • MCP first-tool Authorize gate (ff_authorize_mcp_first_tool)&lt;br/&gt;&lt;br/&gt;Admin → Feature Flags → &lt;b&gt;HITL / Agent Consent&lt;/b&gt;&lt;br/&gt;  • HITL consent gate (ff_hitl_enabled — keep ON in prod)&lt;br/&gt;&lt;br/&gt;MCP Server .env (restart required):&lt;br/&gt;  HTTP_MCP_TRANSPORT_ENABLED=true/false&lt;br/&gt;  TOOL_CALL_TIMEOUT_MS=30000&lt;br/&gt;  MCP_SERVER_RESOURCE_URI=&amp;lt;value&amp;gt; (enables RFC 8707 aud)" vertex="1">
          <mxGeometry height="320" width="560" x="20" y="640" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
