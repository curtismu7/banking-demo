        <mxCell id="r2d" value="✔ DONE" style="text;html=1;strokeColor=#0d6b3e;fillColor=#d4edda;align=center;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#0d6b3e;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="830" y="212" width="120" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r2e" value="Server returns null (no response). Client sends before any tools/call." style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="960" y="212" width="620" height="38" as="geometry" />
        </mxCell>
        <!-- Server lifecycle gate SHOULD -->
        <mxCell id="r3a" value="Server SHOULD NOT process requests before notifications/initialized" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="20" y="250" width="240" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r3b" value="MCP Lifecycle §ordering (SHOULD)" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="270" y="250" width="200" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r3c" value="BankingMCPServer.routeMessage — connection.initialized flag; rejects −32600 before flag set" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="480" y="250" width="340" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r3d" value="✔ DONE" style="text;html=1;strokeColor=#0d6b3e;fillColor=#d4edda;align=center;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#0d6b3e;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="830" y="250" width="120" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r3e" value="Phase F. Exceptions: initialize and ping allowed pre-initialized." style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="960" y="250" width="620" height="38" as="geometry" />
        </mxCell>
        <!-- ═══════════════════════════════════════════════════════════ -->
