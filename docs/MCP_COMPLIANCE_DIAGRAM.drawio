      <mxGeometry x="270" y="324" width="200" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r4c" value="MCPMessageHandler.negotiateProtocolVersion() — supports 2025-11-25 and 2024-11-05" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="480" y="324" width="340" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r4d" value="✔ DONE" style="text;html=1;strokeColor=#0d6b3e;fillColor=#d4edda;align=center;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#0d6b3e;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="830" y="324" width="120" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r4e" value="Phase B. Any 2024-* client version maps to 2024-11-05." style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="960" y="324" width="620" height="38" as="geometry" />
    </mxCell>

    <mxCell id="r5a" value="Client SHOULD disconnect on version mismatch" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="20" y="362" width="240" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r5b" value="MCP Lifecycle §disconnect on mismatch (SHOULD)" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="270" y="362" width="200" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r5c" value="mcpWebSocketClient.js — checks protocolVersion against SUPPORTED_PROTOCOL_VERSIONS; closes + rejects on mismatch" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="480" y="362" width="340" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r5d" value="✔ DONE" style="text;html=1;strokeColor=#0d6b3e;fillColor=#d4edda;align=center;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#0d6b3e;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="830" y="362" width="120" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r5e" value="Phase F. BFF (client role) disconnects; MCP server does not need to." style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="960" y="362" width="620" height="38" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════ -->
