      <mxGeometry x="270" y="436" width="200" height="38" as="geometry" />
    </mxCell>
    <mxCell id="r6c" value="BankingMCPServer.isValidMCPMessage() — rejects id===null; notifications must use notifications/* without id" style="text;html=1;strokeColor=#cccccc;fillColor=#f9f9f9;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
