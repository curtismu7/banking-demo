          <mxGeometry x="270" y="212" width="200" height="38" as="geometry" />
        </mxCell>
        <mxCell id="r2c" value="mcpWebSocketClient.js + MCPMessageHandler.handleMessage case &#39;notifications/initialized&#39;" style="text;html=1;strokeColor=#cccccc;fillColor=#ffffff;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;whiteSpace=wrap;" vertex="1" parent="1">
