          }
        }
      ]
    },
    {
      "name": "Utility \u2014 Set mayAct on User (PATCH)",
      "request": {
        "method": "PATCH",
        "auth": {
          "type": "noauth"
        },
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{pingone_api_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mayAct\": {\n    \"sub\": \"{{PINGONE_CORE_CLIENT_ID}}\"\n  }\n}"
        },
        "url": {
          "raw": "https://api.pingone.{{PINGONE_REGION}}/v1/environments/{{PINGONE_ENVIRONMENT_ID}}/users/{{user_sub}}",
          "protocol": "https",
          "host": [
            "api",
            "pingone",
            "{{PINGONE_REGION}}"
          ],
          "path": [
            "v1",
            "environments",
            "{{PINGONE_ENVIRONMENT_ID}}",
            "users",
            "{{user_sub}}"
          ]
        },
        "description": "Patches the PingOne user record to add or update the mayAct attribute. This one-time setup enables the user's Subject Token to be exchanged in RFC 8693 flows. The mayAct attribute tells PingOne: this user's tokens may be acted-upon by the specified actor client. Run once per test user before running Step 2 for the first time. Requires pingone_api_token from Step 3 and user_sub from Step 1."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Set mayAct: Status 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "if (json.mayAct) {",
              "    console.log('[Set mayAct] Updated mayAct:', JSON.stringify(json.mayAct));",
              "    pm.test('mayAct.sub saved correctly', () => {",
              "        pm.expect(json.mayAct.sub).to.equal(pm.collectionVariables.get('PINGONE_CORE_CLIENT_ID'));",
              "    });",
              "    console.log('[Set mayAct] Now re-run Step 1 to get a fresh Subject Token with the may_act claim.');",
              "}"
            ]
          }
        }
      ]
    }
