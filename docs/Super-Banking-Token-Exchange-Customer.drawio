    <!-- ============================================================ -->
    <mxCell id="step4-box" value="4. MCP Server performs Exchange #2&#xa;Gets its own Actor Token via CC&#xa;Exchanges: Agent Token + MCP Actor Token" style="rounded=1;arcSize=10;fillColor=#ffedd5;strokeColor=#f97316;fontSize=11;fontColor=#7c2d12;" vertex="1" parent="lane-mcp">
