    <!-- ============================================================ -->
    <!-- STEP 3: AI Agent Exchange #1 (2-exchange path) -->
    <!-- ============================================================ -->
    <mxCell id="step3-box" value="3. AI Agent performs Exchange #1&#xa;Gets its own Actor Token via CC&#xa;Exchanges: Subject Token + Agent Actor Token" style="rounded=1;arcSize=10;fillColor=#fef08a;strokeColor=#eab308;fontSize=11;fontColor=#713f12;" vertex="1" parent="lane-agent">
