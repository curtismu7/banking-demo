    <!-- ============================================================ -->
    <!-- RFC Legend -->
    <!-- ============================================================ -->
    <mxCell id="legend" value="&lt;b&gt;Legend:&lt;/b&gt; RFC 8693 exchange = POST /as/token with grant_type=urn:ietf:params:oauth:grant-type:token-exchange | Subject Token = end-user OIDC token | Actor Token = Client Credentials token | act claim = delegation audit trail" style="text;html=1;strokeColor=#e2e8f0;fillColor=#f8fafc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=8;fontColor=#475569;" vertex="1" parent="1">
