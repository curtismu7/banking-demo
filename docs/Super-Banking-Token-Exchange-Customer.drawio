      <mxGeometry x="430" y="30" width="240" height="70" as="geometry" />
    </mxCell>

    <!-- Arrow: Subject Token → Agent Exchange -->
    <mxCell id="arrow-sub-agent" value="Subject Token" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#eab308;fontColor=#854d0e;fontSize=10;" edge="1" parent="1">
