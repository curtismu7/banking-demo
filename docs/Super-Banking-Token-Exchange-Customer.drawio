    <!-- 1-exchange call to RS -->
    <mxCell id="rs-call-1ex" value="Resource Server call&#xa;(1-Exchange path)&#xa;Bearer MCP Token" style="rounded=1;arcSize=10;fillColor=#f3e8ff;strokeColor=#a855f7;fontSize=11;fontColor=#581c87;" vertex="1" parent="lane-rs">
