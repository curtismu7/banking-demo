    <!-- ============================================================ -->
    <!-- PAZ annotation on 2-exchange -->
    <!-- ============================================================ -->
    <mxCell id="paz-box" value="PAZ (PingOne Authorize)&#xa;validates act chain:&#xa;✓ aud == resource-server URI&#xa;✓ act.sub == MCP_CLIENT_ID&#xa;✓ act.act.sub == AI_AGENT_CLIENT_ID" style="rounded=1;arcSize=10;fillColor=#fce7f3;strokeColor=#ec4899;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="lane-rs">
