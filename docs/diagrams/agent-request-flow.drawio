        <mxCell id="flow9" value="9. Display to User&#xa;'Your balance is $2,450.00'" style="endArrow=classic;html=1;rounded=0;strokeColor=#4caf50;strokeWidth=2;dashed=1;" edge="1" parent="1" source="banking-app" target="user">
