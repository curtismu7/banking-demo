        <mxCell id="rfc-annotation3" value="RFC 8707&#xa;Resource Indicators&#xa;Audience Binding" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1040" y="440" width="120" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="rfc-annotation4" value="RFC 9728&#xa;OAuth for MCP&#xa;/.well-known/mcp-server" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="440" width="120" height="40" as="geometry" />
        </mxCell>
        
        <!-- Security Features -->
        <mxCell id="security-features" value="Security Features:&#xa;1. Audience restriction per token&#xa;2. Scope narrowing (least privilege)&#xa;3. Delegation audit trail (act claims)&#xa;4. Token introspection validation&#xa;5. WebSocket encryption (TLS)&#xa;6. Rate limiting per user" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f57c00;fontColor=#e65100;fontSize=9;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="500" width="200" height="100" as="geometry" />
        </mxCell>
        
        <!-- Configuration -->
        <mxCell id="config" value="Configuration:&#xa;ENDUSER_AUDIENCE=https://ai-agent.pingdemo.com&#xa;MCP_RESOURCE_URI=https://mcp-server.pingdemo.com&#xa;PINGONE_API_AUDIENCE=https://api.pingone.com&#xa;USE_AGENT_ACTOR_FOR_MCP=true&#xa;ff_two_exchange_delegation=false" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontColor=#333;fontSize=9;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="280" y="500" width="260" height="100" as="geometry" />
        </mxCell>
        
        <!-- Error Handling -->
        <mxCell id="error-handling" value="Error Handling:&#xa;1. Token validation failures (401)&#xa;2. Scope insufficient (403)&#xa;3. WebSocket connection lost&#xa;4. MCP tool not found&#xa;5. PingOne API rate limits&#xa;6. Delegation chain broken" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#c62828;fontColor=#c62828;fontSize=9;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="580" y="500" width="200" height="100" as="geometry" />
        </mxCell>
        
        <!-- Monitoring -->
