          <mxGeometry x="40" y="320" width="100" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="token1" value="Subject Token&#xa;aud: ai-agent.pingdemo.com&#xa;may_act: {sub: admin-app-id}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;fontColor=#0d47a1;fontSize=9;" vertex="1" parent="1">
