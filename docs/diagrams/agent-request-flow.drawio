        </mxCell>
        
        <mxCell id="rfc-annotation2" value="RFC 8693&#xa;Token Exchange&#xa;Subject &#8594; MCP" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="840" y="440" width="120" height="40" as="geometry" />
