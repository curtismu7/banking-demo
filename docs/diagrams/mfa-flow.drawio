          </mxGeometry>
        </mxCell>
        
        <mxCell id="flow9" value="" style="endArrow=classic;html=1;rounded=0;strokeColor=#2e7d32;strokeWidth=2;" edge="1" parent="1" source="fido2-method" target="completion">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="360" y="310" as="sourcePoint" />
            <mxPoint x="640" y="310" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <mxCell id="flow10" value="" style="endArrow=classic;html=1;rounded=0;strokeColor=#2e7d32;strokeWidth=2;" edge="1" parent="1" source="push-method" target="completion">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="310" as="sourcePoint" />
            <mxPoint x="640" y="310" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- Return to Banking App -->
        <mxCell id="flow11" value="7. Transaction Complete&#xa;Proceed with original action" style="endArrow=classic;html=1;rounded=0;strokeColor=#9c27b0;strokeWidth=3;" edge="1" parent="1" source="completion" target="banking-app">
          <mxGeometry relative="1" as="geometry">
