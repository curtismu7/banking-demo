            <Array as="points">
              <mxPoint x="700" y="340" />
              <mxPoint x="700" y="400" />
              <mxPoint x="360" y="400" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- Session TTL Note -->
        <mxCell id="session-note" value="Session TTL: 5 minutes&#xa;stepUpVerified = Date.now() + 5*60*1000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#c62828;fontColor=#c62828;fontStyle=1;fontSize=10;" vertex="1" parent="1">
