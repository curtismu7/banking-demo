        </mxCell>
        
        <!-- Security Notes -->
        <mxCell id="security-notes" value="Security Features:&#xa;1. Transaction amount validation&#xa;2. Recipient verification&#xa;3. OTP rate limiting&#xa;4. Audit trail logging&#xa;5. Transaction rollback on failure" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f57c00;fontColor=#e65100;fontSize=9;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="380" y="410" width="280" height="80" as="geometry" />
        </mxCell>
        
        <!-- Error Handling -->
        <mxCell id="error-handling" value="Error Scenarios:&#xa;1. OTP expired - resend new code&#xa;2. OTP incorrect - decrement attempts&#xa;3. User rejects - cancel transaction&#xa;4. Network timeout - retry with backoff&#xa;5. Invalid recipient - block transaction" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#c62828;fontColor=#c62828;fontSize=9;fontStyle=0;" vertex="1" parent="1">
