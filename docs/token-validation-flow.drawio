<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-04-08T00:00:00.000Z" agent="Banking-Demo" version="22.1.0" type="device">
  <diagram id="token-validation-flow" name="Token Validation Flow">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="BFF Token Validation — Operator-Configurable Modes (Phase 97)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontSize=16;fontColor=#1a252f;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="1200" height="36" as="geometry" />
        </mxCell>

        <!-- ─── LEFT SIDE: Operator Config Path ─── -->
        <mxCell id="op-label" value="OPERATOR CONFIG PATH" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontSize=11;fontColor=#27ae60;" vertex="1" parent="1">
          <mxGeometry x="80" y="70" width="200" height="24" as="geometry" />
        </mxCell>

        <mxCell id="op-browser" value="Demo Operator&#xa;(Config UI / Browser)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eafaf1;strokeColor=#27ae60;fontColor=#1a252f;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="110" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="op-config-page" value="Config Page&#xa;Token Validation Tab&#xa;GET /api/config/validation-mode" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eafaf1;strokeColor=#27ae60;fontColor=#1a252f;" vertex="1" parent="1">
          <mxGeometry x="100" y="230" width="180" height="70" as="geometry" />
        </mxCell>

        <mxCell id="op-mode-store" value="validationModeConfig.js&#xa;in-memory mode store&#xa;mode: introspection | jwt&#xa;env: VALIDATION_MODE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eafaf1;strokeColor=#27ae60;fontColor=#1a252f;" vertex="1" parent="1">
          <mxGeometry x="100" y="360" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="op-note" value="Runtime mode switch&#xa;— no restart needed" style="text;html=1;strokeColor=#27ae60;fillColor=#f0fdf4;align=center;verticalAlign=middle;fontStyle=2;fontSize=10;fontColor=#27ae60;" vertex="1" parent="1">
          <mxGeometry x="100" y="460" width="180" height="40" as="geometry" />
        </mxCell>

        <!-- Operator → Config Page arrow -->
        <mxCell id="e-op-cfg" value="select mode" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#27ae60;fontColor=#27ae60;" edge="1" source="op-browser" target="op-config-page" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Config Page → Mode Store arrow -->
        <mxCell id="e-cfg-store" value="POST /api/config/&#xa;validation-mode" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#27ae60;fontColor=#27ae60;" edge="1" source="op-config-page" target="op-mode-store" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ─── CENTER: API Request Path ─── -->
        <mxCell id="req-label" value="API REQUEST PATH" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontSize=11;fontColor=#f39c12;" vertex="1" parent="1">
          <mxGeometry x="490" y="70" width="220" height="24" as="geometry" />
        </mxCell>

        <mxCell id="req-arrives" value="API Request arrives&#xa;at BFF (banking_api_server)&#xa;Authorization: Bearer &lt;token&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9e7;strokeColor=#f39c12;fontColor=#1a252f;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="110" width="200" height="70" as="geometry" />
        </mxCell>

        <mxCell id="req-read-mode" value="authenticateToken middleware&#xa;reads getValidationMode()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9e7;strokeColor=#f39c12;fontColor=#1a252f;" vertex="1" parent="1">
          <mxGeometry x="500" y="230" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="req-decision" value="Mode = &#xa;introspection?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fde8cd;strokeColor=#e67e22;fontColor=#1a252f;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="510" y="340" width="180" height="100" as="geometry" />
        </mxCell>

        <!-- Arrives → Read mode -->
        <mxCell id="e-arr-read" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#f39c12;" edge="1" source="req-arrives" target="req-read-mode" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Read mode → Decision -->
        <mxCell id="e-read-dec" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#f39c12;" edge="1" source="req-read-mode" target="req-decision" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ─── RIGHT BRANCH: Introspection ─── -->
        <mxCell id="intr-label" value="YES — INTROSPECTION (RFC 7662)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontSize=11;fontColor=#2980b9;" vertex="1" parent="1">
          <mxGeometry x="780" y="70" width="260" height="24" as="geometry" />
        </mxCell>

        <mxCell id="intr-call" value="POST /as/introspect (RFC 7662)&#xa;to PingOne AS&#xa;body: token=&lt;access_token&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4fd;strokeColor=#2980b9;fontColor=#1a252f;" vertex="1" parent="1">
          <mxGeometry x="800" y="290" width="220" height="70" as="geometry" />
        </mxCell>

        <mxCell id="intr-response" value="PingOne returns:&#xa;{ active: true/false,&#xa;  sub, scope, aud, exp }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4fd;strokeColor=#2980b9;fontColor=#1a252f;" vertex="1" parent="1">
          <mxGeometry x="800" y="410" width="220" height="70" as="geometry" />
        </mxCell>

        <mxCell id="intr-cache" value="Cache result 30s&#xa;(INTROSPECTION_CACHE_TTL)&#xa;key: token hash" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4fd;strokeColor=#2980b9;fontColor=#1a252f;" vertex="1" parent="1">
          <mxGeometry x="800" y="530" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="intr-pros" value="✓ Detects revoked tokens&#xa;✓ Real-time scope/attribute changes&#xa;✓ RFC 7662 compliant&#xa;✗ Requires PingOne network access&#xa;✗ ~50ms (mitigated by cache)" style="text;html=1;strokeColor=#2980b9;fillColor=#d6eaf8;align=left;verticalAlign=middle;fontStyle=0;fontSize=10;fontColor=#1a252f;" vertex="1" parent="1">
          <mxGeometry x="800" y="610" width="220" height="90" as="geometry" />
        </mxCell>

        <!-- Decision → Introspection (YES — right) -->
        <mxCell id="e-dec-intr" value="YES" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2980b9;fontColor=#2980b9;fontStyle=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" source="req-decision" target="intr-call" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-intr-resp" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2980b9;" edge="1" source="intr-call" target="intr-response" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-intr-cache" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2980b9;" edge="1" source="intr-response" target="intr-cache" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ─── LEFT BRANCH: JWT Local ─── -->
        <mxCell id="jwt-label" value="NO — JWT LOCAL VALIDATION (RFC 7519)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontSize=11;fontColor=#8e44ad;" vertex="1" parent="1">
          <mxGeometry x="180" y="520" width="280" height="24" as="geometry" />
        </mxCell>

        <mxCell id="jwt-jwks" value="Fetch JWKS (cached)&#xa;GET /as/jwks (RFC 7517)&#xa;from PingOne" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4ecf7;strokeColor=#8e44ad;fontColor=#1a252f;" vertex="1" parent="1">
          <mxGeometry x="200" y="560" width="200" height="65" as="geometry" />
        </mxCell>

        <mxCell id="jwt-verify" value="Verify RS256 signature&#xa;locally (RFC 7519)&#xa;No network call to PingOne" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4ecf7;strokeColor=#8e44ad;fontColor=#1a252f;" vertex="1" parent="1">
          <mxGeometry x="200" y="670" width="200" height="65" as="geometry" />
        </mxCell>

        <mxCell id="jwt-claims" value="Check exp, aud, iss claims&#xa;Extract sub, scope" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4ecf7;strokeColor=#8e44ad;fontColor=#1a252f;" vertex="1" parent="1">
          <mxGeometry x="200" y="780" width="200" height="55" as="geometry" />
        </mxCell>

        <mxCell id="jwt-pros" value="✓ ~1ms (no network call)&#xa;✓ Works offline / fallback mode&#xa;✓ High-throughput friendly&#xa;✗ Cannot detect revoked tokens&#xa;✗ Changes take ~1h to take effect" style="text;html=1;strokeColor=#8e44ad;fillColor=#f0e6f8;align=left;verticalAlign=middle;fontStyle=0;fontSize=10;fontColor=#1a252f;" vertex="1" parent="1">
          <mxGeometry x="200" y="850" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- Decision → JWT (NO — left/down) -->
        <mxCell id="e-dec-jwt" value="NO" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#8e44ad;fontColor=#8e44ad;fontStyle=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" source="req-decision" target="jwt-jwks" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-jwt-verify" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#8e44ad;" edge="1" source="jwt-jwks" target="jwt-verify" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-jwt-claims" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#8e44ad;" edge="1" source="jwt-verify" target="jwt-claims" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ─── CONVERGE: Both paths → Extract scopes → Allow/Deny ─── -->
        <mxCell id="conv-extract" value="Extract scopes from&#xa;validated token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9e7;strokeColor=#f39c12;fontColor=#1a252f;" vertex="1" parent="1">
          <mxGeometry x="500" y="760" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="conv-scopes" value="requireScopes middleware&#xa;Check requested scope vs token scope" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9e7;strokeColor=#f39c12;fontColor=#1a252f;" vertex="1" parent="1">
          <mxGeometry x="500" y="870" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="conv-allow" value="✅ ALLOW&#xa;Request proceeds" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5f5e3;strokeColor=#27ae60;fontColor=#1a252f;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="990" width="140" height="50" as="geometry" />
        </mxCell>

        <mxCell id="conv-deny" value="❌ DENY&#xa;403 Forbidden" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fadbd8;strokeColor=#e74c3c;fontColor=#1a252f;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="590" y="990" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- Introspection cache → Extract scopes -->
        <mxCell id="e-intr-conv" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#f39c12;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" source="intr-cache" target="conv-extract" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- JWT claims → Extract scopes -->
        <mxCell id="e-jwt-conv" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#f39c12;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" source="jwt-claims" target="conv-extract" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-extract-scope" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#f39c12;" edge="1" source="conv-extract" target="conv-scopes" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-scope-allow" value="scope ok" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#27ae60;fontColor=#27ae60;" edge="1" source="conv-scopes" target="conv-allow" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-scope-deny" value="missing scope" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#e74c3c;fontColor=#e74c3c;" edge="1" source="conv-scopes" target="conv-deny" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ─── HEALTH CHECK SIDE BOX ─── -->
        <mxCell id="health-box" value="Health Check Side Panel" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontSize=11;fontColor=#e67e22;" vertex="1" parent="1">
          <mxGeometry x="1100" y="200" width="220" height="24" as="geometry" />
        </mxCell>

        <mxCell id="health-route" value="GET /api/health/introspection&#xa;RFC 7662 connectivity probe" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdebd0;strokeColor=#e67e22;fontColor=#1a252f;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="240" width="220" height="65" as="geometry" />
        </mxCell>

        <mxCell id="health-ping" value="POST /as/introspect&#xa;with dummy token&#xa;→ PingOne AS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdebd0;strokeColor=#e67e22;fontColor=#1a252f;" vertex="1" parent="1">
          <mxGeometry x="1100" y="350" width="220" height="65" as="geometry" />
        </mxCell>

        <mxCell id="health-result" value="200 connected&#xa;(400 from PingOne = connected;&#xa;invalid token is expected)&#xa;503 failed — cannot reach PingOne" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdebd0;strokeColor=#e67e22;fontColor=#1a252f;" vertex="1" parent="1">
          <mxGeometry x="1100" y="460" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="health-use" value="Operator uses this&#xa;to test before switching&#xa;to introspection mode" style="text;html=1;strokeColor=#e67e22;fillColor=#fef5e7;align=center;verticalAlign=middle;fontStyle=2;fontSize=10;fontColor=#e67e22;" vertex="1" parent="1">
          <mxGeometry x="1100" y="560" width="220" height="50" as="geometry" />
        </mxCell>

        <mxCell id="e-health-ping" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#e67e22;" edge="1" source="health-route" target="health-ping" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-health-result" value="response" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#e67e22;" edge="1" source="health-ping" target="health-result" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Mode store feeds into BFF decision diamond -->
        <mxCell id="e-store-dec" value="getValidationMode()" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#27ae60;fontColor=#27ae60;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" source="op-mode-store" target="req-read-mode" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
