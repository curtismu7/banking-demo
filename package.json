{
  "name": "banking-demo",
  "version": "1.3.1",
  "private": true,
  "engines": {
    "node": "20.x",
    "npm": ">=9"
  },
  "scripts": {
    "test": "bash scripts/run-all-tests.sh",
    "test:api-server": "cd banking_api_server && npm test -- --forceExit",
    "test:mcp-server": "cd banking_mcp_server && npm run test:unit",
    "test:mcp-server:integration": "cd banking_mcp_server && npm run test:integration",
    "test:ui": "cd banking_api_ui && CI=true npm test -- --watchAll=false --passWithNoTests",
    "test:agent": "cd langchain_agent && bash scripts/run-pytest.sh",
    "test:agent:full": "cd langchain_agent && bash scripts/run-pytest.sh tests/",
    "test:agent-ui": "cd langchain_agent/frontend && npm run test:ci",
    "test:mcp-inspector": "cd banking_api_server && npm test -- --testPathPattern=mcp-inspector --forceExit",
    "test:bff-tokens": "cd banking_api_server && npm test -- --testPathPattern='redisWireUrl|bffSessionGating' --forceExit --verbose",
    "test:session": "cd banking_api_server && npm run test:session",
    "test:e2e:ui": "cd banking_api_ui && npm run test:e2e:ci",
    "test:e2e:ui:smoke": "cd banking_api_ui && npm run test:e2e:ui:smoke",
    "release": "node scripts/release.js",
    "setup:vercel": "node scripts/setup-vercel-env.js",
    "setup:vercel:check": "node scripts/setup-vercel-env.js --check",
    "pingone:bootstrap": "node scripts/pingone-bootstrap.js",
    "pingone:bootstrap:probe": "node scripts/pingone-bootstrap.js --probe"
  },
  "dependencies": {
    "@upstash/redis": "^1.37.0",
    "nodemailer": "^8.0.4",
    "vercel": "^32.3.0"
  }
}
